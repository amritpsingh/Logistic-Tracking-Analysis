import os
from typing import Any
from pydantic import BaseModel, ValidationError
import yaml

"""_summary_
Utilities to suppot configuration classes
"""


def load_config(config_file: str) -> dict:
    """_reads provided yaml file as dicts_

    Args:
        config_file (str): _path to the yaml file_

    Returns:
        dict: _The yaml file as dicts_
    """
    assert os.path.exists(config_file), f"Configuration file not found at {config_file}"

    config: Any
    with open(config_file, "r") as f:
        config = yaml.safe_load(f)
    return config


def load_validated_config(config_file: str, schema: BaseModel) -> dict:
    """_summary_

    Args:
        config_file (str): _path to the yaml file_
        schema (BaseModel): _pydantic schema to validate loaded config against_

    Raises:
        Exception: _Should validation fail. Message includes path to the file and the failure reason._

    Returns:
        dict: _The yaml file as validated dicts_
    """
    config = load_config(config_file)

    try:
        schema(**config)
    except ValidationError as e:
        raise Exception(f"Error validating schema of configuration from {config_file}\n{e}")
    return config






