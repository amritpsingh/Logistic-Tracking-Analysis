# parsing_runner.py

"""
Common orchestration for ESS0 → ESS1 parsing jobs.

This module keeps parsing notebooks thin and consistent across forms.

Responsibilities:
    * Instantiate the Parsing transformation.
    * Check target table existence.
    * Read source data.
    * Run Parsing.transform() to produce success and failure DataFrames.
    * Log row-level parsing failures.
    * Verify no-silent-loss coverage.
    * Check target schema for blocking mismatches.
    * Write successfully parsed rows.
    * Log unhandled processing errors.

Notes:
    * Row-level parsing failures are PIA-safe.
    * Raw observed values are not logged.
    * Schema nullability mismatches are intentionally ignored at parsing stage.
"""

from __future__ import annotations

import traceback
from typing import Dict, Optional

from pyspark.sql import DataFrame, SparkSession
from pyspark.sql import functions as F

from transformations.parsing import Parsing
from transformations.schema_operations import (
    build_schema,
    get_schema_mismatches,
    table_exists,
)
from utils.logger import ExceptionLogger


SOURCE_ID_COLUMNS = ["collectionInstance", "responseId", "caseId"]

BLOCKING_SCHEMA_MISMATCH_TYPES = {
    "missing_in_actual",
    "data_type_mismatch",
}


def select_normalised_identity_keys(
    dataframe: DataFrame,
    column_mapping: Optional[Dict[str, str]] = None,
) -> DataFrame:
    """
    Return a comparable source-identity key DataFrame.

    Output columns are always:
        collectionInstance, responseId, caseId

    Args:
        dataframe:
            DataFrame containing identity columns.
        column_mapping:
            Optional mapping from canonical source identity names to the
            actual column names in `dataframe`.

            Example for individual success_df:
                {
                    "collectionInstance": "collection_instance",
                    "responseId": "person_nbr",
                    "caseId": "i_id",
                }

    Why this exists:
        Input, output, and failure DataFrames may use different column names
        for the same source identity values. This function normalises those
        names so the no-silent-loss coverage check can compare them.

    Null handling:
        Nulls are converted to a sentinel only for coverage comparison.
        This avoids Spark's normal NULL != NULL join behaviour.
    """
    mapping = column_mapping or {
        "collectionInstance": "collectionInstance",
        "responseId": "responseId",
        "caseId": "caseId",
    }

    return dataframe.select(
        F.coalesce(
            F.col(mapping["collectionInstance"]).cast("string"),
            F.lit("__NULL__"),
        ).alias("collectionInstance"),
        F.coalesce(
            F.col(mapping["responseId"]).cast("string"),
            F.lit("__NULL__"),
        ).alias("responseId"),
        F.coalesce(
            F.col(mapping["caseId"]).cast("string"),
            F.lit("__NULL__"),
        ).alias("caseId"),
    ).distinct()


def assert_required_source_identity_columns(source_dataframe: DataFrame) -> None:
    """
    Fail fast if any required source identity columns are missing from input.
    """
    missing_columns = [
        source_id_column
        for source_id_column in SOURCE_ID_COLUMNS
        if source_id_column not in source_dataframe.columns
    ]

    if missing_columns:
        raise RuntimeError(
            "Required source identity column(s) missing from input DataFrame: "
            f"{missing_columns}."
        )


def assert_no_silent_loss(
    *,
    source_dataframe: DataFrame,
    success_dataframe: DataFrame,
    failures_dataframe: DataFrame,
    flow: Parsing,
) -> None:
    """
    Assert every input source record is represented either in:
        * success_dataframe, or
        * failures_dataframe

    This prevents silent row loss during parsing.

    The check uses source identity:
        collectionInstance + responseId + caseId

    Output key columns are inferred from YAML by looking for output variables
    whose expression maps from:
        collectionInstance, responseId, caseId
    """
    output_identity_columns = flow.infer_output_pk_columns()

    input_keys = select_normalised_identity_keys(source_dataframe)

    output_keys = select_normalised_identity_keys(
        success_dataframe,
        column_mapping={
            "collectionInstance": output_identity_columns["collectionInstance"],
            "responseId": output_identity_columns["responseId"],
            "caseId": output_identity_columns["caseId"],
        },
    )

    failure_keys = select_normalised_identity_keys(failures_dataframe)

    covered_keys = output_keys.unionByName(failure_keys).distinct()

    missing_keys = input_keys.join(
        covered_keys,
        SOURCE_ID_COLUMNS,
        "left_anti",
    )

    missing_count = missing_keys.count()

    if missing_count > 0:
        raise RuntimeError(
            f"Coverage invariant violated: {missing_count} input record(s) "
            "are neither in the success output nor in the failure set."
        )


def get_blocking_schema_mismatches(
    *,
    spark: SparkSession,
    table_path: str,
    output_variables,
) -> list[dict]:
    """
    Return schema mismatches that block writing at parsing stage.

    Parsing stage blocks on:
        * missing_in_actual
        * data_type_mismatch

    Parsing stage ignores:
        * nullability_mismatch

    Nullability validation is handled later during data contract validation.
    """
    expected_schema = build_schema(output_variables)
    actual_schema = spark.table(table_path).schema

    schema_mismatches = get_schema_mismatches(
        actual=actual_schema,
        expected=expected_schema,
    )

    return [
        mismatch
        for mismatch in schema_mismatches
        if mismatch["mismatch_type"] in BLOCKING_SCHEMA_MISMATCH_TYPES
    ]


def log_schema_mismatches(
    *,
    logger: ExceptionLogger,
    mismatches: list[dict],
    target_table: str,
) -> None:
    """
    Log blocking schema mismatches.

    expected/observed columns are not written to the exceptions table.
    The expected/actual schema details are included only in the PIA-safe
    message text.
    """
    for mismatch in mismatches:
        logger.log(
            rule="schema_mismatch",
            event_type="PARSING",
            variable_name=mismatch["column"],
            message=(
                f"Target table schema {mismatch['mismatch_type']} "
                f"for column '{mismatch['column']}'. "
                f"Expected={mismatch['expected']!r}, "
                f"Actual={mismatch['actual']!r}. "
                f"Target table={target_table}."
            ),
        )


def log_missing_target_table(
    *,
    spark: SparkSession,
    source_table: Optional[str],
    target_table: str,
) -> None:
    """
    Log missing target table as a file-level parsing exception.
    """
    with ExceptionLogger.for_task(
        spark=spark,
        collection_instance_id=None,
        source_table=source_table,
        target_table=target_table,
    ) as logger:
        logger.log(
            rule="file_not_found",
            event_type="PARSING",
            message=(
                f"Target table does not exist: {target_table}. "
                "Create it via the upstream DDL job before running parsing."
            ),
        )


def log_processing_error(
    *,
    spark: SparkSession,
    source_table: Optional[str],
    target_table: Optional[str],
    stack_trace: str,
) -> None:
    """
    Log unhandled parsing job error.
    """
    with ExceptionLogger.for_task(
        spark=spark,
        collection_instance_id=None,
        source_table=source_table,
        target_table=target_table,
    ) as logger:
        logger.log(
            rule="processing_error",
            event_type="PARSING",
            message="Unhandled exception during parsing job execution.",
            stack_trace=stack_trace,
        )


def run_parsing_job(
    *,
    spark: SparkSession,
    config_file: str,
) -> None:
    """
    Execute one ESS0 → ESS1 parsing job.

    This function is intended to be called by thin Databricks notebooks.

    Example:
        run_parsing_job(
            spark=spark,
            config_file="individual/individual_parsing",
        )

    Args:
        spark:
            Active SparkSession.
        config_file:
            Transformation YAML path relative to the collection folder,
            e.g.:
                "individual/individual_parsing"
                "dwelling/dwelling_parsing"
                "household/household_parsing"
                "household/dwelling_person_parsing"
    """
    flow = Parsing(spark, config_file)

    input_dataset = flow._transform_config.input_datasets[0]
    output_dataset = flow._transform_config.output_datasets[0]
    output_variables = output_dataset.variables

    known_failure_logged = False

    try:
        # ------------------------------------------------------------------
        # 1. Ensure target table exists.
        # ------------------------------------------------------------------
        if not table_exists(spark, output_dataset.path):
            log_missing_target_table(
                spark=spark,
                source_table=input_dataset.path,
                target_table=output_dataset.path,
            )

            known_failure_logged = True
            raise RuntimeError(
                f"Target table {output_dataset.path} does not exist."
            )

        # ------------------------------------------------------------------
        # 2. Read source data.
        # ------------------------------------------------------------------
        data = flow.read()

        if "responses" not in data:
            raise RuntimeError(
                f"Expected input dataset key 'responses'. "
                f"Found keys={list(data.keys())}."
            )

        responses_dataframe = data["responses"]

        assert_required_source_identity_columns(responses_dataframe)

        # ------------------------------------------------------------------
        # 3. Transform.
        # ------------------------------------------------------------------
        success_dataframe, failures_dataframe = flow.transform(data)

        with ExceptionLogger.for_task(
            spark=spark,
            collection_instance_id=None,
            source_table=input_dataset.path,
            target_table=output_dataset.path,
        ) as logger:

            # --------------------------------------------------------------
            # 4. Log row-level parsing failures.
            # --------------------------------------------------------------
            flow.log_failures(logger, failures_dataframe)

            # --------------------------------------------------------------
            # 5. No-silent-loss coverage check.
            # --------------------------------------------------------------
            assert_no_silent_loss(
                source_dataframe=responses_dataframe,
                success_dataframe=success_dataframe,
                failures_dataframe=failures_dataframe,
                flow=flow,
            )

            # --------------------------------------------------------------
            # 6. Schema mismatch check.
            # --------------------------------------------------------------
            blocking_schema_mismatches = get_blocking_schema_mismatches(
                spark=spark,
                table_path=output_dataset.path,
                output_variables=output_variables,
            )

            if blocking_schema_mismatches:
                log_schema_mismatches(
                    logger=logger,
                    mismatches=blocking_schema_mismatches,
                    target_table=output_dataset.path,
                )

                known_failure_logged = True
                raise RuntimeError(
                    f"Schema mismatch in {output_dataset.path}: "
                    f"{len(blocking_schema_mismatches)} blocking mismatch(es)."
                )

            # --------------------------------------------------------------
            # 7. Write successfully parsed rows.
            # --------------------------------------------------------------
            flow.write(success_dataframe)

    except Exception:
        if not known_failure_logged:
            log_processing_error(
                spark=spark,
                source_table=input_dataset.path if "input_dataset" in locals() else None,
                target_table=output_dataset.path if "output_dataset" in locals() else None,
                stack_trace=traceback.format_exc(),
            )

        raise




