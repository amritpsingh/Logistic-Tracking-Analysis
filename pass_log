from typing import Dict, List
from definitions import CONFIGS_DIR
from enum import Enum
from config_models.collection_config_schema import CollectionConfigSchema
from config_models import yaml_functions
import logging

logger = logging.getLogger(__name__)

"""_summary_
Classes which represent the collection's configuration.
"""


class Collection(Enum):
