    schema_a = {f.name: f.dataType.simpleString() for f in df_a.schema if f.name in common_cols}
    schema_b = {f.name: f.dataType.simpleString() for f in df_b.schema if f.name in common_cols}

    type_diffs = {
        c: (schema_a[c], schema_b[c])
        for c in common_cols
