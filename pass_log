from typing import List

from pyspark.sql import SparkSession
from pyspark.sql.types import (
    ByteType,
    StructType,
    StructField,
    StringType,
    IntegerType,
    ShortType,
    LongType,
    TimestampType,
)
from pyspark.sql.utils import AnalysisException

from config_models.transformation_config import VariableConfig

_TYPE_MAP = {
    "string": StringType(),
    "integer": IntegerType(),
    "tinyint": ByteType(),
    "short": ShortType(),
    "long": LongType(),
    "timestamp": TimestampType(),
}


def build_schema(output_variables: List[VariableConfig]) -> StructType:
    """
    Build expected schema using YAML variable definitions.
    Uses v.name as physical column name.
    """
    fields = []

    for variable in output_variables:
        if variable.internal:
            continue

        if variable.type not in _TYPE_MAP:
            raise ValueError(
                f"Unsupported type {variable.type!r} for variable {variable.name!r}. "
                f"Supported: {sorted(_TYPE_MAP)}"
            )

        fields.append(
            StructField(variable.name, _TYPE_MAP[variable.type], variable.allow_blank)
        )

    return StructType(fields)


def get_schema_mismatches(*, actual: StructType, expected: StructType) -> List[dict]:
    """
    Compare expected schema against actual schema (order-insensitive).

    Returns a list of mismatch records:
        {
            "column": "<column_name>",
            "mismatch_type": "missing_in_actual" |
                             "data_type_mismatch" |
                             "nullability_mismatch",
            "expected": "<expected_value>",
            "actual": "<actual_value>" | None,
        }

    Notes:
    - Extra columns in actual schema are ignored.
    - One column can generate multiple records (e.g., type + nullability mismatch).
    """

    actual_fields = {field.name: field for field in actual.fields}
    mismatches = []

    for expected_field in expected.fields:
        column_name = expected_field.name

        if column_name not in actual_fields:
            mismatches.append({
                "column": column_name,
                "mismatch_type": "missing_in_actual",
                "expected": f"{expected_field.dataType.simpleString()} (nullable={expected_field.nullable})",
                "actual": None,
            })
            continue

        actual_field = actual_fields[column_name]

        # Compare data types
        if actual_field.dataType != expected_field.dataType:
            mismatches.append({
                "column": column_name,
                "mismatch_type": "data_type_mismatch",
                "expected": expected_field.dataType.simpleString(),
                "actual": actual_field.dataType.simpleString(),
            })

        # Compare nullability
        if actual_field.nullable != expected_field.nullable:
            mismatches.append({
                "column": column_name,
                "mismatch_type": "nullability_mismatch",
                "expected": f"nullable={expected_field.nullable}",
                "actual": f"nullable={actual_field.nullable}",
            })

    return mismatches


def validate_schema(df, expected_schema):
    # Ignore column order
    actual = StructType(sorted(df.schema, key=lambda x: x.name))
    expected = StructType(sorted(expected_schema, key=lambda x: x.name))
    if actual != expected:
        raise ValueError(
            f"""
Schema mismatch detected!

Expected schema:
{expected}

Actual schema:
{actual}
"""
        )


def table_exists(spark: SparkSession, table_path: str) -> bool:
    """
    Return True when the table can be referenced via the metastore catalog.

    Used as a precondition for schema-mismatch checks and as a gate
    before parsing — when the target table does not yet exist, parsing
    output cannot be written, so the job should fail early.
    """
    try:
        spark.table(table_path).limit(0).collect()
        return True
    except AnalysisException:
        return False










