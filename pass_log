# parsing.py

from config_models.transformation_config import VariableConfig
from transformations.abstract_transformation import AbstractTransformation

from functools import reduce

from pyspark.sql import DataFrame
from pyspark.sql.functions import (
    col,
    from_json,
    expr,
    current_timestamp,
    posexplode,
    explode,
    length,
    lit,
    when,
    nullif,
    trim,
    size
)
from pyspark.sql.types import (
    MapType,
    StringType,
    ArrayType
)


# Source record identity columns available in all parsing input YAMLs.
SOURCE_ID_COLUMNS = ("collectionInstance", "responseId", "caseId")


# YAML type → Spark SQL type for ANSI-safe try_cast.
_TRY_CAST_TYPES = {
    "int": "int",
    "integer":   "int",
    "tinyint":   "tinyint",
    "short":     "smallint",
    "long":      "bigint",
    "timestamp": "timestamp",
}


class Parsing(AbstractTransformation):
    def __init__(self, spark, config_file: str):
        super().__init__(spark, config_file)

    # ──────────────────────────────────────────────────────────────
    # Expression formats can be anything in the left column and then
    # gets rewrite to the expression in the right column
    #   data:a              → data_json['a']
    #   data:a:b:c          → get_json_object(data_json['a'], '$.b.c')
    #   loop_x:y:z          → get_json_object(loop_x_json['y'], '$.z')
    # ──────────────────────────────────────────────────────────────
    def _rewrite_json_expression(self, expression: str, json_scopes: set) -> str:
        # Fast exit for when ":" not in expression
        if ":" not in expression:
            return expression

        parts = expression.split(":")
        scope = parts[0]
        keys = parts[1:]

        # Only rewrite known JSON scopes
        if scope not in json_scopes:
            return expression

        # Base map access
        base = f"{scope}_json['{keys[0]}']"

        # Simple access: data:key
        if len(keys) == 1:
            return base

        # Nested JSON inside string → get_json_object
        json_path = ".".join(keys[1:])
        return f"get_json_object({base}, '$.{json_path}')"



    # Build a Spark column from variable config (non-explode only)
    def _build_column(self, variable: VariableConfig, json_scopes: set):
        name = variable.name
        var_type = variable.type

        alias = getattr(variable, "alias", None)
        expression = getattr(variable, "expression", None)

        # Explode expressions handled earlier
        if expression and expression.startswith(("explode:", "posexplode:")):
            return None

        # ── Expression
        if expression:
            spark_expr = self._rewrite_json_expression(expression, json_scopes)
            col_expr = expr(spark_expr)
            expr_str = spark_expr  # Track the original SQL string

        elif alias:
            col_expr = col(alias)
            expr_str = alias

        else:
            raise ValueError(
                f"Variable '{name}' must define either 'expression' or 'alias'"
            )

        # ── Type casting
        if var_type == "string":
            col_expr = col_expr.cast("string")
        elif var_type in _TRY_CAST_TYPES:
            sql_type = _TRY_CAST_TYPES[var_type]
            col_expr = expr(
                f"try_cast(nullif(replace(trim(cast(({expr_str}) as string)), ',', ''), '') as {sql_type})"
            )
        else:
            raise ValueError(
                f"Unsupported type {var_type!r} for variable {name!r}."
            )

        return col_expr.alias(name)



    # ──────────────────────────────────────────────────────────────────
    # Helpers
    # ──────────────────────────────────────────────────────────────────

    @staticmethod
    def _nonblank(column_expression):
        """
        Column predicate: value is not null and not empty after trimming.
        """
        return column_expression.isNotNull() & (
            length(trim(column_expression.cast("string"))) > 0
        )


    def _failure_columns(self, *, variable_name: str, failure_type: str, message: str):
        return [
            col("collectionInstance").cast("string").alias("collectionInstance"),
            col("responseId").cast("string").alias("responseId"),
            col("caseId").cast("string").alias("caseId"),
            lit(variable_name).alias("variable_name"),
            lit(failure_type).alias("failure_type"),
            lit(message).alias("message"),
        ]

    def _get_json_input_columns(self) -> set:
        """
        Names of input variables declared as type: json in YAML.
        """
        return {
            input_variable.name
            for input_dataset in self._transform_config.input_datasets
            for input_variable in (input_dataset.variables or [])
            if getattr(input_variable, "type", None) == "json"
        }


    def _get_explode_specs(self) -> list:
        """
        Collect explode / posexplode specs from output variables.
        """
        output_vars = self._transform_config.output_datasets[0].variables
        explode_specs = []

        for output_variable in output_vars:
            expression = getattr(output_variable, "expression", None)
            if not expression:
                continue

            if expression.startswith(("explode:", "posexplode:")):
                explode_type, scope, path = expression.split(":", 2)
                explode_specs.append(
                    {
                        "name": output_variable.name,
                        "explode_type": explode_type,
                        "scope": scope,
                        "path": path,
                    }
                )

        return explode_specs


    def _get_cast_sql_types(self) -> set:
        """
        SQL cast types declared by non-internal output variables.
        Used by log_failures() to log cast failures by SQL type.
        """
        sql_types = set()

        for output_variable in self._transform_config.output_datasets[0].variables:
            if getattr(output_variable, "internal", False):
                continue

            if output_variable.type in _TRY_CAST_TYPES:
                sql_types.add(_TRY_CAST_TYPES[output_variable.type])

        return sql_types


    def _empty_failures_df(self) -> DataFrame:
        """
        Empty PIA-safe failures DataFrame.
        """
        return self.spark.createDataFrame(
            [],
            """
            collectionInstance string,
            responseId string,
            caseId string,
            variable_name string,
            failure_type string,
            message string
            """,
        )


    # ──────────────────────────────────────────────────────────────────
    # Parsing
    # ──────────────────────────────────────────────────────────────────

    # Main transformation
    def transform(self, data):
        """
        Parse the input batch and return both the projected output and
        the failure observations.

        Pipeline:
            1. Parse JSON-typed input columns into map<string,string>.
            2. Apply each YAML-declared explode (outer variant).
            3. Record one failure row per detected issue:
                 * json_parse        — raw JSON did not parse
                 * explode_parse     — array JSON did not parse
                 * cast_<sql_type>   — try_cast returned NULL on non-blank input
            4. Exclude any input row whose primary key appears in the
               failure set, then project the configured output columns.

        Args:
            data: Dict of input DataFrames keyed by the YAML `key`
                (e.g. {"responses": <input DataFrame>}).
            pk_column: Name of the input column to use as the primary
                key for failure records (e.g. "responseId" for
                individual, "uoi" for household).

        Returns:
            (success_df, failures_df):
                success_df: DataFrame in target-table shape, only rows
                    that passed every check.
                failures_df: DataFrame[response_id, variable_name,
                    observed, failure_type], one row per failure
                    observation, deduplicated on (response_id,
                    variable_name, observed).

        Note:
            Returns a tuple, not a single DataFrame. Callers should
            drive read → transform → log_failures → write explicitly
            from the notebook
        """
        responses_df = data["responses"]

        for source_id_column in SOURCE_ID_COLUMNS:
            if source_id_column not in responses_df.columns:
                raise ValueError(
                    f"Required source identity column {source_id_column!r} "
                    f"not found in input DataFrame."
                )

        # 1. Parse JSON input columns
        json_input_columns = self._get_json_input_columns()

        parsed_df = responses_df

        for json_column_name in json_input_columns:
            parsed_df = parsed_df.withColumn(
                f"{json_column_name}_json",
                from_json(
                    col(json_column_name).cast("string"),
                    MapType(StringType(), StringType()),
                ),
            )

        json_scopes = set(json_input_columns)

        failure_dataframes = []

        # 2. JSON parse failures — raw column non-blank but parsed result NULL
        for json_column_name in sorted(json_input_columns):
            failure_dataframes.append(
                parsed_df.filter( self._nonblank(col(json_column_name)) & col(f"{json_column_name}_json").isNull() )
                .select(
                    *self._failure_columns(
                        variable_name=json_column_name,
                        failure_type="json_parse",
                        message=(f"JSON parsing failed for input field '{json_column_name}'."
                        ),
                    )
                )
            )



        # 3. Apply explode(s) and capture explode parse failures
        exploded_df = parsed_df

        for explode_spec in self._get_explode_specs():
            name = explode_spec["name"]
            explode_type = explode_spec["explode_type"]
            scope = explode_spec["scope"]
            path = explode_spec["path"]

            raw_array_expr = col(f"{scope}_json").getItem(path).cast("string")

            array_expr = from_json(
                raw_array_expr,
                ArrayType(MapType(StringType(), StringType())),
            )

            # Failure if explode source is missing/blank OR cannot parse as expected array.
            explode_failure_condition = (
                ~self._nonblank(raw_array_expr)
                | (self._nonblank(raw_array_expr) & array_expr.isNull())
                | (size(array_expr) == 0)
            )

            failure_dataframes.append(
                exploded_df
                .filter(explode_failure_condition)
                .select(
                    *self._failure_columns(
                        variable_name=f"{scope}:{path}",
                        failure_type="explode_parse",
                        message=(
                            f"Explode input '{scope}:{path}' is missing, blank, empty"
                            f"or could not be parsed as array<map<string,string>>."
                        ),
                    )
                )
            )

            # Use normal explode/posexplode.
            # Invalid source rows have already been captured in failure_dataframes.
            if explode_type == "posexplode":
                exploded_df = exploded_df.select(
                    "*",
                    posexplode(array_expr).alias(f"{name}_index", name),
                )
            else:
                exploded_df = exploded_df.withColumn(
                    name,
                    explode(array_expr),
                )

            # Register exploded value as a new JSON scope
            exploded_df = exploded_df.withColumn(f"{name}_json", col(name))
            json_scopes.add(name)

        output_vars = self._transform_config.output_datasets[0].variables



        # 4. Cast failures — try_cast returns NULL on non-blank input
        for output_variable in output_vars:
            if getattr(output_variable, "internal", False):
                continue

            if output_variable.type not in _TRY_CAST_TYPES:
                continue

            expression = getattr(output_variable, "expression", None)
            if not expression:
                continue

            # Explode driver variables are handled above
            if expression.startswith(("explode:", "posexplode:")):
                continue

            base_expr = self._rewrite_json_expression(expression, json_scopes)
            sql_type = _TRY_CAST_TYPES[output_variable.type]

            raw_value_expr = expr(base_expr).cast("string")
            casted_value_expr = expr(
                f"try_cast(nullif(replace(trim(cast(({base_expr}) as string)), ',', ''), '') as {sql_type})"
            )

            failure_dataframes.append(
                exploded_df
                .select(
                    "collectionInstance",
                    "responseId",
                    "caseId",
                    raw_value_expr.alias("_raw_value"),
                    casted_value_expr.alias("_casted_value"),
                )
                .filter(
                    self._nonblank(col("_raw_value"))
                    & col("_casted_value").isNull()
                )
                .select(
                    *self._failure_columns(
                        variable_name=output_variable.name,
                        failure_type=f"cast_{sql_type}",
                        message=(
                            f"Type cast failed for variable "
                            f"'{output_variable.name}'. Expected {sql_type}."
                        ),
                    )
                )
            )


        # 5. Combine and deduplicate failures (suppresses duplicates after explode)
        if failure_dataframes:
            failures_df = (
                reduce( lambda left_df, right_df: left_df.unionByName(right_df), failure_dataframes )
                .dropDuplicates( ["collectionInstance", "responseId", "caseId", "variable_name", "failure_type"] )
            )
        else:
            failures_df = self._empty_failures_df()


        # 6. Exclude source records that had parsing failures.
        failed_keys_df = failures_df.select(
            "collectionInstance",
            "responseId",
            "caseId",
        ).distinct()

        # Use null-safe equality so failed records are excluded even if
        # a key component is null.
        join_condition = (
            exploded_df["collectionInstance"].eqNullSafe(failed_keys_df["collectionInstance"])
            & exploded_df["responseId"].eqNullSafe(failed_keys_df["responseId"])
            & exploded_df["caseId"].eqNullSafe(failed_keys_df["caseId"])
        )

        clean_df = exploded_df.join(
            failed_keys_df,
            join_condition,
            "left_anti",
        )


        # 7. Build final output columns
        # Internal columns are used only for intermediate processing.
        output_columns = [
            col_expr
            for output_variable in output_vars
            if not getattr(output_variable, "internal", False)
            if (col_expr := self._build_column(output_variable, json_scopes)) is not None
        ]

        success_df = clean_df.select(*output_columns)

        return success_df, failures_df



    # ──────────────────────────────────────────────────────────────────
    # Public — logging
    # ──────────────────────────────────────────────────────────────────

    def log_failures(self, logger, failures_df: DataFrame, *, event_type: str = "PARSING") -> None:
        """
        Log parsing failures to the exceptions table via ExceptionLogger.
        """

        for failure_type in ("json_parse", "explode_parse"):
            failure_subset = (
                failures_df
                .filter(col("failure_type") == failure_type)
                .select(
                    "collectionInstance",
                    "responseId",
                    "caseId",
                    "variable_name",
                    "message",
                )
            )

            logger.log_dataframe(
                failure_subset,
                rule=failure_type,
                event_type=event_type,
                variable_name_column="variable_name",
                response_id_column="responseId",
                case_id_column="caseId",
                collection_instance_id_column="collectionInstance",
                message_column="message",
            )

        # Cast failures use one registry rule: "cast"
        cast_failures_df = (
            failures_df
            .filter(col("failure_type").startswith("cast_"))
            .select(
                "collectionInstance",
                "responseId",
                "caseId",
                "variable_name",
                "message",
            )
        )

        logger.log_dataframe(
            cast_failures_df,
            rule="cast",
            event_type=event_type,
            variable_name_column="variable_name",
            response_id_column="responseId",
            case_id_column="caseId",
            collection_instance_id_column="collectionInstance",
            message_column="message",
        )


    # ──────────────────────────────────────────────────────────────────
    # Public — output PK inference
    # ──────────────────────────────────────────────────────────────────

    def infer_output_pk_columns(self) -> dict:
        """
        Infer output columns that map from the source record identity columns.
        """
        source_to_output_column = {}

        for output_variable in self._transform_config.output_datasets[0].variables:
            if getattr(output_variable, "internal", False):
                continue

            expression = getattr(output_variable, "expression", None)

            if expression in SOURCE_ID_COLUMNS:
                source_to_output_column[expression] = output_variable.name

        missing_source_columns = [
            source_column
            for source_column in SOURCE_ID_COLUMNS
            if source_column not in source_to_output_column
        ]

        if missing_source_columns:
            raise ValueError(
                "Could not infer output primary key mapping for source column(s): "
                f"{missing_source_columns}. "
                "Each source identity column must have a non-internal output variable "
                "with expression equal to the source column name."
            )

        return source_to_output_column



