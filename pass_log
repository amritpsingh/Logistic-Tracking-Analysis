    }

    result = {
        "only_in_a": sorted(cols_a - cols_b),
        "only_in_b": sorted(cols_b - cols_a),
        "common_cols": common_cols,
        "type_diffs": type_diffs,
    }

    print("=" * 60)
    print("SCHEMA COMPARISON")
    print("=" * 60)
    print(f"Columns only in {table_a} ({len(result['only_in_a'])}): {result['only_in_a'] or 'none'}")
    print(f"Columns only in {table_b} ({len(result['only_in_b'])}): {result['only_in_b'] or 'none'}")
