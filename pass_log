"""
Search utilities for both filesystem and Databricks catalogs.

Notebook usage - Search Files:
    from utils.search_resources import search_files
    search_files(search_str, root_dir=ROOT_DIR)
    search_files(search_str, root_dir=ROOT_DIR, extensions=[".py", ".yml"])

Notebook usage - Search Catalogs:
    from utils.search_resources import search_catalogs
    result = search_catalogs(search_str, catalogs="search_catalogs", spark=spark)
    result  # displays matches
    
    # Generate DROP statements
    drop_stmts = result.get_drop_statements("main")
    for stmt in drop_stmts:
        print(stmt)
    
    # Execute the statements
    for stmt in drop_stmts:
        spark.sql(stmt)
"""
import os
import argparse
from dataclasses import dataclass, field

_SKIP_DIRS = {"__pycache__", ".venv", "node_modules"}


@dataclass
class SearchResult:
    search_string: str
    root_dir: str
    folder_matches: list[str] = field(default_factory=list)
    name_matches: list[str] = field(default_factory=list)
    content_matches: list[str] = field(default_factory=list)

    def __repr__(self) -> str:
        lines = [
            f"\nSearch string : '{self.search_string}'",
            f"Root directory: {self.root_dir}\n",
        ]
        if self.folder_matches:
            lines.append(f"--- Folders matching by NAME ({len(self.folder_matches)}) ---")
            lines.extend(f"  {p}" for p in self.folder_matches)
        else:
            lines.append("--- No folders matched by name ---")

        if self.name_matches:
            lines.append(f"\n--- Files matching by NAME ({len(self.name_matches)}) ---")
            lines.extend(f"  {p}" for p in self.name_matches)
        else:
            lines.append("\n--- No files matched by name ---")

        if self.content_matches:
            lines.append(f"\n--- Files matching by CONTENT ({len(self.content_matches)}) ---")
            lines.extend(f"  {p}" for p in self.content_matches)
        else:
            lines.append("\n--- No files matched by content ---")

        return "\n".join(lines)


def search_files(
    search_string: str,
    root_dir: str,
    extensions: list[str] | None = None,
) -> SearchResult:
    """
    Search for folders, files whose name, or content that contains search_string.

    Args:
        search_string: The string to search for (case-insensitive).
        root_dir:      Root directory to walk. Pass ROOT_DIR from definitions.py.
        extensions:    Optional list of extensions to include, e.g. [".py", ".yml"].
                       If None, all files are searched.

    Returns:
        SearchResult with folder_matches, name_matches, and content_matches lists.
        Printing the result displays a formatted summary.
    """
    result = SearchResult(search_string=search_string, root_dir=root_dir)
    needle = search_string.lower()

    for dirpath, dirnames, filenames in os.walk(root_dir):
        # Check folder names
        dirs_to_remove = []
        for d in dirnames:
            if d.startswith(".") or d in _SKIP_DIRS:
                dirs_to_remove.append(d)
            elif needle in d.lower():
                rel_folder = os.path.relpath(os.path.join(dirpath, d), root_dir)
                result.folder_matches.append(rel_folder)
        
        dirnames[:] = [d for d in dirnames if d not in dirs_to_remove]

        for filename in filenames:
            if extensions and not any(filename.endswith(ext) for ext in extensions):
                continue

            filepath = os.path.join(dirpath, filename)
            rel_path = os.path.relpath(filepath, root_dir)

            if needle in filename.lower():
                result.name_matches.append(rel_path)
                continue

            try:
                with open(filepath, encoding="utf-8", errors="ignore") as f:
                    if needle in f.read().lower():
                        result.content_matches.append(rel_path)
            except (OSError, PermissionError):
                pass

    return result


@dataclass
class CatalogSearchResult:
    search_string: str
    catalogs: str
    results: list[tuple[str, str]] = field(default_factory=list)  # (schema, table) tuples

    def __repr__(self) -> str:
        lines = [
            f"\nSearch string : '{self.search_string}'",
            f"Catalogs       : {self.catalogs}\n",
        ]
        if self.results:
            lines.append(f"--- Matches found ({len(self.results)}) ---")
            for schema, table in self.results:
                if table:
                    lines.append(f"  {schema}.{table}")
                else:
                    lines.append(f"  {schema} (schema)")
        else:
            lines.append("--- No matches found ---")

        return "\n".join(lines)

    def get_drop_statements(self, catalog: str) -> list[str]:
        """Generate DROP SQL statements for matched schemas and tables."""
        statements = []
        for schema, table in self.results:
            if table:
                statements.append(f"DROP TABLE IF EXISTS {catalog}.{schema}.{table};")
            else:
                statements.append(f"DROP SCHEMA IF EXISTS {catalog}.{schema} CASCADE;")
        return statements


def search_catalogs(
    search_string: str,
    catalogs: str,
    spark,
) -> CatalogSearchResult:
    """
    Search for schemas and tables matching search_string in specified catalogs.

    Args:
        search_string: The string to search for (case-insensitive).
        catalogs:      Comma-separated catalog names (e.g., "main,other").
        spark:         SparkSession object.

    Returns:
        CatalogSearchResult with list of (schema, table) tuples.
        Use .get_drop_statements(catalog_name) to generate DROP statements.
    """
    result = CatalogSearchResult(search_string=search_string, catalogs=catalogs)
    needle = search_string.lower()
    catalog_list = [c.strip() for c in catalogs.split(",")]

    for catalog in catalog_list:
        try:
            spark.sql(f"USE CATALOG {catalog}")
            schemas_df = spark.sql(f"SHOW SCHEMAS IN {catalog}").select("databaseName")
            schemas = [row.databaseName for row in schemas_df.collect()]

            for schema in schemas:
                # Check if schema name matches
                if needle in schema.lower():
                    result.results.append((schema, ""))

                # Get tables in schema
                try:
                    tables_df = spark.sql(f"SHOW TABLES IN {schema}")
                    for row in tables_df.collect():
                        table_name = row.tableName
                        if needle in table_name.lower():
                            result.results.append((schema, table_name))
                except Exception:
                    pass  # Skip schemas where SHOW TABLES fails

        except Exception as e:
            print(f"Warning: Could not search catalog '{catalog}': {e}")

    return result













