import os
import yaml
from pathlib import Path
import json


def load_config(file_name: str) -> dict:
    ext = Path(file_name).suffix.lower()
    with open(file_name, "r") as f:
        if ext in {".yml", ".yaml"}:
            return yaml.safe_load(f)
        elif ext == ".json":
            return json.load(f)
        else:
            raise ValueError(
                f"Unsupported config file type '{ext}'. "
                "Only .yml, .yaml, and .json are supported."
            )


def deepest_category_code_for_descriptor(items, descriptor):
    descriptor_lower = descriptor.lower()
    deepest = None
    deepest_code = None

    for item in items:
        if item["descriptor"].lower() == descriptor_lower:
            depth = item["levelDepth"]
            if deepest is None or depth > deepest:
                deepest = depth
                deepest_code = item["code"]

    return deepest_code


def deepest_category_code_for_descriptors_dict(category_json, descriptors):
    # Map lowercase → original descriptor
    desc_map = {d.lower(): d for d in descriptors}

    # Track best result per lowercase descriptor
    results = {d.lower(): (None, None) for d in descriptors}

    for item in category_json:
        desc_lower = item["descriptor"].lower()

        if desc_lower in results:
            depth = item["levelDepth"]
            code = item["code"]

            current_depth, _ = results[desc_lower]
            if current_depth is None or depth > current_depth:
                results[desc_lower] = (depth, code)

    # Convert back to original casing in output
    return {desc_map[k]: code for k, (_, code) in results.items()}


def deepest_category_code_for_descriptors_df(category_json, descriptors):
    # Map lowercase → original descriptor
    desc_map = {d.lower(): d for d in descriptors}

    # Track best (deepest) result per lowercase descriptor
    results = {d.lower(): {"levelDepth": None, "code": None} for d in descriptors}

    for item in category_json:
        desc_lower = item["descriptor"].lower()

        if desc_lower in results:
            depth = item["levelDepth"]
            code = item["code"]

            current_depth = results[desc_lower]["levelDepth"]
            if current_depth is None or depth > current_depth:
                results[desc_lower] = {"levelDepth": depth, "code": code}

    # Build DataFrame with original descriptor casing
    rows = [
        {"descriptor": desc_map[desc_lower], "code": data["code"]}
        for desc_lower, data in results.items()
    ]

    return pd.DataFrame(rows)





