Also provides variables: 
PROJECT_DIR = the pathh to the src folder
ROOT_DIR = the path to the checkout folder
CONFIGS_DIR = the path to the configuration folder
"""
dbutils: DBUtils
if "dbutils" not in globals():
    w = WorkspaceClient()
    dbutils = w.dbutils
else:
    dbutils = dbutils

notebook_path = (
    dbutils.notebook.entry_point.getDbutils().notebook().getContext().notebookPath().get()
)
notebook_file = os.path.basename(notebook_path)

PROJECT_DIR = os.path.dirname(os.path.dirname(os.path.abspath(notebook_file)))  # src folder
ROOT_DIR = os.path.dirname(PROJECT_DIR)
CONFIGS_DIR = os.path.join(ROOT_DIR, "configuration")

if PROJECT_DIR not in sys.path:
    sys.path.append(PROJECT_DIR)

if ROOT_DIR not in sys.path:
    sys.path.append(ROOT_DIR)
load_dotenv()

spark: SparkSession
if "spark" not in globals():
    spark = SparkSession.getActiveSession()
    if spark is None:
        spark = DatabricksSession.builder.serverless().getOrCreate()
else:
    spark = spark

