from __future__ import annotations
from typing import TYPE_CHECKING

from config_models.residual_config import ResidualConfig

if TYPE_CHECKING:
    from config_models.transformation_config import DatasetConfig


class VariableConfig:
    """_summary_
    Configration for an individual variable as read from transformation yml file
    """

    name: str
    dataset: DatasetConfig
    type: str
    classification: str
    level: int
    allow_blank: bool
    numeric_code_length: int
    min_value: int
    max_value: int
    allow_blank: bool
    buffer_words_table: str | None
    lookup_table: str | None
    fuzzy_tolerance: float | None
    residuals: ResidualConfig
    expression: str = ""
    internal: bool = False
    is_pk: bool = False

    _alias: str = None

    def __init__(
        self,
        name: str,
        dataset: DatasetConfig,
        alias: str = None,
        type: str = None,
        classification: str = None,
        level: int = None,
        numeric_code_length: int = None,
        min_value: int = None,
        max_value: int = None,
        allow_blank: bool = True,
        buffer_words_table: str | None = None,
        lookup_table: str | None = None,
        fuzzy_tolerance: float | None = None,
        residuals: ResidualConfig = None,
        expression: str = None,
        internal: bool = False,
        is_pk: bool = False
    ):
        self.name = name
        self.dataset = dataset
        self._alias = alias
        self.type = type
        self.classification = classification
        self.level = level
        self.numeric_code_length = numeric_code_length
        self.min_value = min_value
        self.max_value = max_value
        self.allow_blank = allow_blank
        self.buffer_words_table = buffer_words_table
        self.lookup_table = lookup_table
        self.fuzzy_tolerance = fuzzy_tolerance
        self.residuals = ResidualConfig() if residuals is None else ResidualConfig(**residuals)
        self.expression = expression
        self.internal = internal
        self.is_pk = is_pk

    def __repr__(self):
        return (
            f"VariableConfig(name={self.name!r}, alias={self.alias!r}, type={self.type!r}, "
            f"classification={self.classification!r}, level={self.level!r}, "
            f"allow_blank={self.allow_blank!r})"
        )

    @property
    def alias(self):
        return self._alias if self._alias is not None else self.name








