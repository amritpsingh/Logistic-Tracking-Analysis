"""
Incremental filtering utilities for SCD Type 2 (Slowly Changing Dimension Type 2) processing.

This module provides efficient incremental processing using:
1. Watermark-based filtering (time-based) for fast pre-filtering of source records
2. Row hash comparison for detecting actual changes within the watermark window
3. Current row filtering (effective_to_date = 9999-12-31 23:59:59) to compare only active rows

This enables efficient incremental SCD Type 2 UPSERT operations where:
- New records are inserted
- Changed records close the old version (set effective_to_date) and insert a new version
- Unchanged records are skipped
"""

from pyspark.sql import DataFrame, SparkSession
from pyspark.sql.functions import col, lit

SCD_CURRENT_ROW_SENTINEL = "9999-12-31T23:59:59+13:00"


def filter_by_watermark(
    source_df: DataFrame,
    watermark_timestamp,
    watermark_col: str = "sys_create_date",
) -> DataFrame:
    """
    Filter source_df to only records created/updated after the watermark timestamp.
    
    This is the first-pass filter for efficiency — only processes new records
    since the last run.
    
    Args:
        source_df: Source DataFrame to filter
        watermark_timestamp: Timestamp to filter from (exclusive)
        watermark_col: Name of timestamp column (default: "sys_create_date")
    
    Returns:
        DataFrame containing only records after the watermark
    """
    if watermark_timestamp is None:
        # First run — process all records
        return source_df
    
    return source_df.filter(col(watermark_col) > watermark_timestamp)


def get_new_and_changed_records(
    source_df: DataFrame,
    target_table: str,
    spark: SparkSession,
    pk_hash_col: str = "pk_hash",
    row_hash_col: str = "row_hash",
) -> DataFrame:
    """
    Filter source_df to only records that are new or have changed.
    
    Compares source records against the target table using pk_hash and row_hash.
    Only compares against current rows (effective_to_date = 9999-12-31T23:59:59+13:00) per SCD Type 2.
    
    Logic:
    - New records: pk_hash not found in current target rows
    - Changed records: pk_hash exists in current rows but row_hash differs
    
    This is the second-pass filter (post-watermark) to detect actual changes.
    
    Args:
        source_df: Source DataFrame to filter
        target_table: Target Delta table name to compare against
        spark: SparkSession
        pk_hash_col: Name of primary key hash column (default: "pk_hash")
        row_hash_col: Name of row hash column (default: "row_hash")
    
    Returns:
        DataFrame containing only new and changed records from source_df
    """
    try:
        existing = spark.table(target_table)
        # Spark Connect can defer missing table/permission failures until action time.
        # Trigger a tiny action eagerly so failures are handled by this try/except.
        existing.limit(1).collect()
        
        # Filter to current rows only (SCD Type 2: canonical timestamp sentinel value)
        existing = existing.filter(
            col("effective_to_date").cast("timestamp")
            == lit(SCD_CURRENT_ROW_SENTINEL).cast("timestamp")
        )
        
        # Select pk_hash and row_hash from existing table
        existing_keys = existing.select(
            col(pk_hash_col).alias("existing_pk_hash"),
            col(row_hash_col).alias("existing_row_hash")
        ).distinct()
        
        # Left join to identify new and changed records
        joined = source_df.join(
            existing_keys,
            source_df[pk_hash_col] == existing_keys["existing_pk_hash"],
            how="left"
        )
        
        # Filter to keep only new (no match) or changed (row_hash differs) records
        result = joined.filter(
            (col("existing_pk_hash").isNull()) |  # New record (no match in target)
            (col(row_hash_col) != col("existing_row_hash"))  # Changed record
        ).select(source_df.columns)
        
        return result
        
    except Exception as e:
        # Table doesn't exist yet or other error - process all records
        print(f"Warning: Could not filter against {target_table}: {e}")
        print("Processing all records from source.")
        return source_df






