class CollectionConfig:
    """_summary_
    Represents the collection's configuration.
    Configration is loaded from "{CONFIGS_DIR}/collections/{collection.name}/config.yml"
    and environment variable PROCESS_SANDBOX_USER
    """

    _config: Dict
    _collection_name: str
    _environment: str
    _steady_states: List[_SteadyState]
    _root_names: _RootNames
    _overrides: _Overrides
    _sandbox: str | None = None

    def __init__(self, collection: Collection, environment):
        assert isinstance(collection, Collection)
        config_path = f"{CONFIGS_DIR}/collections/{collection.name}/config.yml"
        logger.debug(f"Loading configuration file {config_path}")
        print(f"Loading configuration file {config_path}")
        self._config = yaml_functions.load_validated_config(config_path, CollectionConfigSchema)
        self._collection_name = self._config["name"]
        self._environment = environment
        self._steady_states = [_SteadyState(**data) for data in self._config["steady_states"]]
        self._overrides = _Overrides(**self._config["overrides"])
        self._root_names = _RootNames(**self._config["root_names"])

        sandbox = os.getenv("PROCESS_SANDBOX_USER")
        if (sandbox is not None) and (not sandbox.isspace()):
            assert sandbox.isalnum(), "%PROCESS_SANDBOX_USER% contains non-alphanumeric characters"
            self._sandbox = f"development_{sandbox}"

        assert environment is not None, "environment must be specified"
        assert (
            environment in self._config["valid_environments"]
        ), f"{environment} not a valid environment for {collection.name}"

    def _validate_dataset_name(self, dataset: str):
        assert (
            dataset in self._config["valid_datasets"]
        ), f"Dataset {dataset} not defined in config.yml for {self._collection_name}"

    def _validate_steady_state_value(self, steady_state: str):
        assert steady_state in [
            ss.name for ss in self._steady_states
        ], f"Steady state {steady_state} not defined in config.yml for {self._collection_name}"

    """
    returns catalog calculated as
    <root_names.external_catalog_prefix>_<environment> for external datasets
    <root_names.catalog_prefix>_<environment> for internal steady states
    unless there is a yaml override at overrides.catalog
    """

    def get_catalog(self, steady_state: str):
        self._validate_steady_state_value(steady_state)
        overridden = next(
            (
                x
                for x in self._overrides.catalogs
                if x.environment == self._environment and x.steady_state == steady_state
            ),
            None,
        )
        if overridden is not None:
            return overridden.use_catalog

        is_external_steady_state = next(
            (x.is_external for x in self._steady_states if x.name == steady_state), None
        )
        if is_external_steady_state == True:
            return f"{self._root_names.external_catalog_prefix}{self._environment}"
        return f"{self._root_names.catalog_prefix}{self._environment}"

    """
    returns catalog and schema as
    <root_names.external_catalog_prefix>_<environment>.survey_response_<steady_state> for external datasets
    <root_names.catalog_prefix>.<collection>_<steady_state> for other steady states

    e.g.  : socpophousdata1_dev.social_census_classified

    If PROCESS_SANDBOX_USER is defined and we are using steady state defined in sand_box_steady_states, the 
    sandbox schema is used
    """

    def get_catalog_and_schema(self, steady_state: str):
        catalog = self.get_catalog(steady_state)

        if self._sandbox is not None and steady_state in self._config["sand_box_steady_states"]:
            return f"{catalog}.{self._sandbox}"

        overrides = [x for x in self._overrides.schema if x.steady_state == steady_state]
        if len(overrides):
            override_by_env = next(
                (x for x in overrides if x.environment == self._environment), None
            )
            if override_by_env is not None:
                return f"{catalog}.{override_by_env.use_schema}"
            overridden = next((x for x in overrides if x.environment is None), None)
            if overridden is not None:
                return f"{catalog}.{overridden.use_schema}"

        is_external_steady_state = next(
            (x.is_external for x in self._steady_states if x.name == steady_state), None
        )

        if is_external_steady_state == True:
            return f"{catalog}.{self._root_names.external_schema_prefix}{steady_state}"

        return f"{catalog}.{self._collection_name}_{steady_state}"

    def get_table_path(self, dataset, steady_state):
        schema = self.get_catalog_and_schema(steady_state)
        valid_datasets = next(
            (x.datasets for x in self._steady_states if x.name == steady_state), None
        )
        assert valid_datasets is not None, f"No datasets defined for steady state {steady_state}"
        assert (
            dataset in valid_datasets
        ), f"Dataset {dataset} not defined for steady state {steady_state}"
        overridden = next(
            (
                x
                for x in self._overrides.tables
                if x.dataset == dataset and x.steady_state == steady_state
            ),
            None,
        )
        if overridden is not None:
            return f"{schema}.{overridden.use_table}"
        return f"{schema}.{dataset}"








