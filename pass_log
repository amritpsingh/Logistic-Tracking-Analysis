from delta.tables import DeltaTable
from pyspark.sql import DataFrame, SparkSession
from config_models.dataset_config import DatasetConfig
from pyspark.sql.functions import (
    col,
    concat_ws,
    current_timestamp,
    lit,
    max as spark_max,
    row_number,
    sha2,
    to_utc_timestamp,
)
from pyspark.sql.window import Window

from utils.incremental_filter import filter_by_watermark, get_new_and_changed_records

_AUDIT_COLS = {
    "pk", "pk_hash", "row_hash", "sys_create_date", "created_date",
    "effective_from_date", "effective_to_date", "run_id", "insert_time_utc"
}

SCD_CURRENT_ROW_SENTINEL = "9999-12-31T23:59:59+13:00"


def write_table(
    df: DataFrame,
    output_dataset: DatasetConfig,
    spark: SparkSession,
    merge_mode: bool = True,
    run_id: str = None,
):
    """
    Write DataFrame to Delta table with incremental SCD Type 2 UPSERT or full overwrite.
    
    Automatically adds audit columns (pk, pk_hash, row_hash, created_date, effective_from_date, 
    effective_to_date, etc.) based on is_pk flags in the output_dataset variable definitions.

    When merge_mode=True, incremental filtering and SCD Type 2 merge are applied:
      0. Deduplication — keep only the latest record per primary key (by max sys_create_date)
            1. _get_dynamic_watermark() — read MAX(insert_time_utc) from target table
            2. filter_by_watermark() — time-based pre-filter using sys_create_date (fast)
            3. _add_audit_columns()  — compute pk_hash and row_hash on parsed data
            4. get_new_and_changed_records() — hash-based filter against current rows
            5. _merge_into_table()   — SCD Type 2 UPSERT: close old rows, insert new versions

    When merge_mode=False, overwrites the entire table.

    Args:
        df: DataFrame to write (post-parsing, pre-audit columns)
        output_dataset: DatasetConfig containing variable definitions
        spark: SparkSession
        merge_mode: If True, perform incremental SCD Type 2 UPSERT; if False, full overwrite
        run_id: Workflow run ID for lineage tracking
    """
    audit_ddl = [
        "pk STRING",
        "pk_hash STRING",
        "row_hash STRING",
        "created_date TIMESTAMP",
        "effective_from_date TIMESTAMP",
        "effective_to_date TIMESTAMP",
        "run_id STRING",
        "insert_time_utc TIMESTAMP",
    ]
    data_ddl = [f"{c.alias} {c.type.upper()}" for c in output_dataset.variables if not c.internal]
    ddl_cols = ",\n".join(data_ddl + audit_ddl)
    output_table = output_dataset.path
    sql_query = f"""CREATE TABLE IF NOT EXISTS {output_table} ( {ddl_cols} ) USING DELTA"""

    spark.sql(sql_query)
    out_table_cols = [col(v.name).alias(v.alias) for v in output_dataset.variables if not v.internal]
    df = df.select(*out_table_cols)

    # Deduplicate: keep only the latest record per primary key (by max sys_create_date)
    pk_cols = [v.alias for v in output_dataset.variables if not v.internal and v.is_pk]
    if pk_cols and "sys_create_date" in df.columns:
        window_spec = Window.partitionBy(*pk_cols).orderBy(col("sys_create_date").desc())
        df = df.withColumn("_rn", row_number().over(window_spec)).filter(col("_rn") == 1).drop("_rn")
    
    if merge_mode:
        # Step 1: Dynamically calculate watermark from target table state
        watermark = _get_dynamic_watermark(spark, output_table)

        # Step 2: Time-based pre-filter using watermark (fast)
        df = filter_by_watermark(df, watermark)

        # Step 3: Add audit columns (computes pk_hash and row_hash)
        df = _add_audit_columns(df, output_dataset, run_id, spark)

        # Step 4: Hash-based filter — only new or changed records
        df = get_new_and_changed_records(df, output_table, spark)

        # Step 5: UPSERT into Delta table
        merged_record_count = df.count()
        if merged_record_count > 0:
            _merge_into_table(df, output_table, spark)
    else:
        df = _add_audit_columns(df, output_dataset, run_id, spark)
        df.write.mode("overwrite").option("overwriteSchema", "false").saveAsTable(output_table)

def _get_dynamic_watermark(spark: SparkSession, target_table: str):
    """
    Calculate watermark dynamically from target table state.

    Returns MAX(insert_time_utc) from the target table, or None when empty.
    """
    result = spark.table(target_table).agg(spark_max(col("insert_time_utc")).alias("watermark")).collect()
    if result and result[0][0]:
        return result[0][0]
    return None


def _add_audit_columns(
    df: DataFrame,
    output_dataset: DatasetConfig,
    run_id: str,
    spark: SparkSession,
) -> DataFrame:
    """
    Append audit columns to a DataFrame based on variable config.

    pk       : pipe-delimited composite of all is_pk=true columns
    pk_hash  : SHA-256 of pk
    row_hash : SHA-256 of all non-pk, non-audit, non-internal data columns
    created_date / effective_from_date : current UTC timestamp
    effective_to_date : default sentinel value 9999-12-31T23:59:59+13:00 (timestamp)
    run_id   : workflow run identifier
    """
    tz = spark.conf.get("spark.sql.session.timeZone")
    now = to_utc_timestamp(current_timestamp(), tz)

    pk_cols = [v.alias for v in output_dataset.variables if not v.internal and v.is_pk]
    data_cols = [
        v.alias for v in output_dataset.variables
        if not v.internal and not v.is_pk and v.alias not in _AUDIT_COLS
    ]

    if not pk_cols:
        # Some outputs (for example classification/reference-style datasets used in unit
        # tests) may not define business keys. Fall back to hashing all data columns so
        # audit columns can still be populated and writes do not fail. 
        fallback_cols = [
            v.alias for v in output_dataset.variables
            if not v.internal and v.alias not in _AUDIT_COLS
        ]
        if not fallback_cols:
            raise ValueError(
                f"Output dataset '{output_dataset.dataset}' has no usable non-internal columns "
                "to derive audit hashes."
            )
        pk_cols = fallback_cols
        data_cols = fallback_cols

    return (
        df
        .withColumn("pk", concat_ws("|", *[col(c) for c in pk_cols]))
        .withColumn("pk_hash", sha2(col("pk"), 256))
        .withColumn("row_hash", sha2(concat_ws("|", *[col(c) for c in data_cols]), 256))
        .withColumn("created_date", now)
        .withColumn("effective_from_date", now)
        .withColumn("effective_to_date", lit(SCD_CURRENT_ROW_SENTINEL).cast("timestamp"))
        .withColumn("run_id", lit(run_id))
        .withColumn("insert_time_utc", now)
    )


def _merge_into_table(df: DataFrame, target_table: str, spark: SparkSession):
    """
    Perform SCD Type 2 merge on target table using pk_hash as the key.
    
    Implements Slowly Changing Dimension Type 2 logic:
    - MATCHED (current row) with row_hash changed: Close old row (effective_to_date = now), insert new version
    - MATCHED (current row) but row_hash unchanged: no action (skip)
    - NOT MATCHED: Insert new row
    
    The join condition matches only "current" records (effective_to_date = 9999-12-31T23:59:59+13:00).
    After closing an old row, the new version (from source) no longer matches the join condition,
    so it gets inserted via the WHEN NOT MATCHED clause.
    
    Args:
        df: DataFrame with new/updated records (must include audit columns: pk_hash, row_hash, 
                                               effective_from_date, effective_to_date)
        target_table: Target Delta table name
        spark: SparkSession
    """
    delta_table = DeltaTable.forName(spark, target_table)
    
    # Ensure required columns exist
    if "pk_hash" not in df.columns or "row_hash" not in df.columns:
        raise ValueError("DataFrame must contain 'pk_hash' and 'row_hash' columns for MERGE operation")
    
    tz = spark.conf.get("spark.sql.session.timeZone")
    now = to_utc_timestamp(current_timestamp(), tz)
    
    # Merge logic: match on pk_hash AND current row filter (effective_to_date = 9999-12-31)
    delta_table.alias("t").merge(
        df.alias("s"),
        (
            "t.pk_hash = s.pk_hash AND "
            f"cast(t.effective_to_date as timestamp) = cast('{SCD_CURRENT_ROW_SENTINEL}' as timestamp)"
        )
    ).whenMatchedUpdate(
        condition="t.row_hash != s.row_hash",
        set={"effective_to_date": now}
    ).whenNotMatchedInsert(
        values={col_name: col(f"s.{col_name}") for col_name in df.columns}
    ).execute()






