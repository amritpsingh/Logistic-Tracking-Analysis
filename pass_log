from abc import ABC
from typing import Any, List
from config_models.dataset_config import DatasetConfig
from config_models.variable_config import VariableConfig
from definitions import CONFIGS_DIR

from config_models.collection_config import Collection, CollectionConfig
from config_models.transformation_config_schema import TransformationConfigSchema
from config_models import yaml_functions


class TransformationConfig(ABC):
    """_summary_
    Class which represent the transformation's configuration.
    """

    collection_config: CollectionConfig
    _transform_config: Any
    _input_datasets: List[DatasetConfig]
    _output_datasets: List[DatasetConfig]

    def __init__(self, collection: Collection, environment, transformation):
        self.collection_config = CollectionConfig(collection, environment)
        config_path = f"{CONFIGS_DIR}/collections/{collection.name}/{transformation}.yml"
        self._transform_config = yaml_functions.load_validated_config(
            config_path, TransformationConfigSchema
        )
        self._input_datasets = []
        self._output_datasets = []

        for var in self._transform_config["input_variables"]:
            t = DatasetConfig(**var)
            t.path = self.collection_config.get_table_path(t.dataset, t.steady_state)
            self._input_datasets.append(t)
        for var in self._transform_config["output_variables"]:
            t = DatasetConfig(**var)
            t.path = self.collection_config.get_table_path(t.dataset, t.steady_state)
            self._output_datasets.append(t)

    @property
    def input_datasets(self):
        """_summary_
        The list of input datasets
        """
        return self._input_datasets

    @property
    def output_datasets(self):
        """_summary_
        The list of output datasets
        """
        return self._output_datasets

    def get_input_dataset(self, dataset: str):
        """_summary_
        Get a specific input dataset by alias, or name if alias is not defined.
        Raises ValueError if dataset is not found
        Args:
            dataset (str): the dataset name
        """
        res = next((x for x in self._input_datasets if x.dataset == dataset), None)
        if res is None:
            raise ValueError(f"Input dataset {dataset} not found")
        return res

    def get_output_dataset(self, dataset: str):
        """_summary_
        Get a specific output dataset by alias, or name if alias is not defined.
        Raises ValueError if dataset is not found
        Args:
            dataset (str): the dataset alias (or name)
        """
        res = next((x for x in self._output_datasets if x.key == dataset), None)
        if res is None:
            raise ValueError(f"Output dataset {dataset} not found")
        return res

    def get_input_variable(self, dataset: str, variable: str) -> VariableConfig:
        """_summary_
        Get a specific input variable by name (not alias).
        Args:
            dataset (str): the dataset alias (or name)
            variable (str): the variable name (not alias).

        Raises:
            ValueError: if dataset or variable is not found

        Returns:
            VariableConfig: The variable
        """
        ds = self.get_input_dataset(dataset)
        if ds.include_all_variables or ds.variables is None:
            raise ValueError(
                f"Individual input variables for dataset {dataset} not defined as 'all' was specified in the yaml"
            )
        for var in ds.variables:
            if var.name == variable:
                return var
        raise ValueError(f"Input dataset {dataset} does not have a variable with name {variable}")

    def get_output_variable(self, dataset: str, variable: str) -> VariableConfig:
        """_summary_
        Get a specific output variable by name (not alias).
        Args:
            dataset (str): the dataset alias (or name)
            variable (str): the variable name (not alias)

        Raises:
            ValueError: if dataset or variable is not found

        Returns:
            VariableConfig: The variable
        """
        ds = self.get_output_dataset(dataset)

        for var in ds.variables:
            if var.name == variable:
                return var
        raise ValueError(f"Output dataset {dataset} does not have a variable with name {variable}")

    @property
    def etc(self):
        """_summary_
        Custom transform config as loaded from yaml file.
        Returns a dict of the custom config
        """
        if "etc" in self._transform_config:
            return self._transform_config["etc"]
        return None









