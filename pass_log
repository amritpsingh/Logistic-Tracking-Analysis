"""
Table comparison utilities for Databricks.

Provides functions to compare two Delta tables:
- Schema / column differences
- Data type differences on common columns
- PK-based row comparison showing column-level diffs (new_value | old_value)
"""

from pyspark.sql import DataFrame, SparkSession
from pyspark.sql import functions as F


def compare_schemas(df_a: DataFrame, df_b: DataFrame, name_a: str, name_b: str) -> dict:
    """
    Compare the schemas of two DataFrames.

    Returns a dict with:
        only_in_a   : columns present in A but not B
        only_in_b   : columns present in B but not A
        common_cols : sorted list of columns present in both
        type_diffs  : dict of column -> (type_in_a, type_in_b) for mismatched types
    """
    cols_a = set(df_a.columns)
    cols_b = set(df_b.columns)
    common_cols = sorted(cols_a & cols_b)

    schema_a = {f.name: f.dataType.simpleString() for f in df_a.schema if f.name in common_cols}
    schema_b = {f.name: f.dataType.simpleString() for f in df_b.schema if f.name in common_cols}

    type_diffs = {
        c: (schema_a[c], schema_b[c])
        for c in common_cols
        if schema_a[c] != schema_b[c]
    }

    result = {
        "only_in_a": sorted(cols_a - cols_b),
        "only_in_b": sorted(cols_b - cols_a),
        "common_cols": common_cols,
        "type_diffs": type_diffs,
    }

    print("=" * 60)
    print("SCHEMA COMPARISON")
    print("=" * 60)
    print(f"Columns only in {name_a} ({len(result['only_in_a'])}): {result['only_in_a'] or 'none'}")
    print(f"Columns only in {name_b} ({len(result['only_in_b'])}): {result['only_in_b'] or 'none'}")
    print(f"Common columns ({len(common_cols)}): {common_cols}")

    if type_diffs:
        print("\nTYPE DIFFERENCES ON COMMON COLUMNS:")
        for col_name, (type_a, type_b) in type_diffs.items():
            print(f"  {col_name}: {name_a}={type_a}  |  {name_b}={type_b}")
    else:
        print("\nNo type differences on common columns.")

    return result


def compare_rows(
    df_a: DataFrame,
    df_b: DataFrame,
    name_a: str,
    name_b: str,
    pk_cols: list,
    compare_cols: list = None,
) -> DataFrame:
    """
    Join two DataFrames on pk_cols and compare column values side-by-side.

    Each non-PK column in the result shows:
      - 'MATCH'               if values are equal (including both NULL)
      - 'new_value | old_value' if values differ

    Only rows with at least one difference are returned.

    Args:
        df_a:         DataFrame A (the "new" table)
        df_b:         DataFrame B (the "old" table)
        name_a:       Label for table A
        name_b:       Label for table B
        pk_cols:      Columns to join on (must exist in both tables)
        compare_cols: Columns to compare. Defaults to all common non-PK columns.

    Returns:
        DataFrame with PK columns + one diff column per compared column.
        Only rows with at least one difference are included.
    """
    all_common = set(df_a.columns) & set(df_b.columns)
    pk_cols = [c for c in pk_cols if c in all_common]
    if not pk_cols:
        raise ValueError(f"None of the specified pk_cols exist in both tables: {pk_cols}")

    if compare_cols:
        non_pk_cols = [c for c in compare_cols if c in all_common and c not in pk_cols]
    else:
        non_pk_cols = [c for c in sorted(all_common) if c not in pk_cols]

    # Cast all columns to string for uniform comparison
    a_cols = pk_cols + non_pk_cols
    df_a_str = df_a.select(*[F.col(c).cast("string").alias(c) for c in a_cols])
    df_b_str = df_b.select(*[F.col(c).cast("string").alias(c) for c in a_cols])

    # Prefix non-PK columns in B to avoid name clash after join
    df_b_prefixed = df_b_str
    for c in non_pk_cols:
        df_b_prefixed = df_b_prefixed.withColumnRenamed(c, f"_b_{c}")

    joined = df_a_str.join(df_b_prefixed, on=pk_cols, how="inner")

    # Build MATCH / "a | b" diff column for each compared column
    for c in non_pk_cols:
        joined = joined.withColumn(
            c,
            F.when(
                (F.col(c).eqNullSafe(F.col(f"_b_{c}"))),
                F.lit("MATCH")
            ).otherwise(
                F.concat_ws(
                    " | ",
                    F.coalesce(F.col(c), F.lit("NULL")),
                    F.coalesce(F.col(f"_b_{c}"), F.lit("NULL")),
                )
            )
        ).drop(f"_b_{c}")

    # Keep only rows where at least one column is not MATCH
    diff_filter = " OR ".join([f"`{c}` != 'MATCH'" for c in non_pk_cols])
    result = joined.filter(diff_filter) if diff_filter else joined

    count_total = df_a_str.join(df_b_prefixed, on=pk_cols, how="inner").count()
    count_diff = result.count()

    # Drop columns where every row is MATCH (they add no value to the output)
    if count_diff > 0 and non_pk_cols:
        has_diff = result.agg(
            *[F.max(F.when(F.col(c) != "MATCH", F.lit(1)).otherwise(F.lit(0))).alias(c) for c in non_pk_cols]
        ).collect()[0].asDict()
        diff_cols = [c for c in non_pk_cols if has_diff.get(c) == 1]
    else:
        diff_cols = []

    result = result.select(*pk_cols, *diff_cols)

    print("=" * 60)
    print(f"ROW COMPARISON  ({name_a}  vs  {name_b})")
    print("=" * 60)
    print(f"Rows in {name_a}:         {df_a.count()}")
    print(f"Rows in {name_b}:         {df_b.count()}")
    print(f"Rows with matching PKs:   {count_total}")
    print(f"Rows with differences:    {count_diff}")
    print(f"PK columns:               {pk_cols}")
    print(f"Compared columns:         {non_pk_cols}")
    print(f"Columns with diffs:       {diff_cols}")
    print(f"\nColumn format: new_value | old_value  (MATCH if identical)")

    return result


def compare_tables(
    spark: SparkSession,
    table_a: str,
    table_b: str,
    pk_cols: list,
    compare_cols: list = None,
) -> DataFrame:
    """
    Full comparison of two Delta tables: schema differences and PK-based row diffs.

    Args:
        spark:        SparkSession
        table_a:      Fully qualified table name — the "new" table (catalog.schema.table)
        table_b:      Fully qualified table name — the "old" table (catalog.schema.table)
        pk_cols:      Columns that uniquely identify a row (used for joining)
        compare_cols: Columns to compare values for. Defaults to all common non-PK columns.

    Returns:
        DataFrame of rows with at least one differing column value.
        Each column shows 'MATCH' or 'new_value | old_value'.
    """
    df_a = spark.table(table_a)
    df_b = spark.table(table_b)

    compare_schemas(df_a, df_b, table_a, table_b)
    return compare_rows(df_a, df_b, table_a, table_b, pk_cols, compare_cols)

    """
    Compare the schemas of two DataFrames.

    Returns a dict with:
        only_in_a   : columns present in A but not B
        only_in_b   : columns present in B but not A
        common_cols : sorted list of columns present in both
        type_diffs  : dict of column -> (type_in_a, type_in_b) for mismatched types
    """
