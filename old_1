    # ────────────────────────────────────────────────────────

    def log_dataframe(
        self,
        df,
        *,
        event_type: str,
        rule_name: Optional[str] = None,
        rule_name_column: Optional[str] = None,
        message: Optional[str] = None,
        message_column: Optional[str] = None,
        response_id_column: str,
        case_id_column: Optional[str] = None,
        collection_instance_id_column: Optional[str] = None,
        variable_name: Optional[str] = None,
        variable_name_column: Optional[str] = None,
    ) -> int:
        """
        Log every row of a DataFrame as a separate event record.

        Use when an upstream step produces a DataFrame of event rows (e.g. an imputation
        step logging one event per row processed).

        Per-row vs constant fields:

            Per-row (DataFrame columns):
                * response_id_column (required)
                * message_column (optional)
                * case_id_column (optional)
                * collection_instance_id_column (optional)
                * variable_name_column (optional)
                * rule_name_column (optional)

            Constant for the whole call:
                * event_type (required)
                * rule_name (optional)
                * message (optional alternative to message_column)
                * variable_name (optional alternative to variable_name_column)

        Message shape:
            * Provide message="constant text" when every row represents the same event message.
            * Provide message_column="msg" when each row has its own message text.
            Exactly one of these must be provided.

        Rule-name shape:
            * Pass rule_name="my_rule" when every row uses the same rule name.
            * Pass rule_name_column="rule_name" when each row has its own rule name.
            * Pass neither when rule_name is not applicable.

        Collection instance sourcing:
            * If collection_instance_id_column is provided, the per-row value is used.
            * Otherwise, the logger falls back to the context collection_instance_id.

        Args:
            df: PySpark DataFrame, one row per event.
            event_type: Event category applied to every row.
            rule_name: Constant rule name applied to every row.
            rule_name_column: DataFrame column when each row has its own rule name.
            message: Constant message text (mutually exclusive with message_column).
            message_column: DataFrame column holding per-row message text.
            response_id_column: DataFrame column holding response_id values (required).
            case_id_column: Optional DataFrame column holding case_id values.
            collection_instance_id_column: Optional DataFrame column holding collection_instance_id values.
            variable_name: Constant variable name (mutually exclusive with variable_name_column).
            variable_name_column: DataFrame column holding per-row variable names.

        Returns:
            Number of records appended to the buffer.

        Raises:
            ValueError: if message/message_column constraints are violated, if variable_name and
                variable_name_column are both set, if referenced columns are missing, or if the
                DataFrame exceeds the safety size limit.

        Performance note:
            Driver-side iteration via collect(). Safe up to ~100k rows.
        """

        if message is None and message_column is None:
            raise ValueError(
                "Either `message` (constant) or `message_column` (per-row) "
                "must be supplied — every event needs a message."
            )
        if message is not None and message_column is not None:
            raise ValueError(
                "Pass either `message` (constant) or `message_column` "
                "(per-row), not both."
            )
        if variable_name is not None and variable_name_column is not None:
            raise ValueError(
                "Pass either `variable_name` (constant) or "
                "`variable_name_column` (per-row), not both."
            )

        if response_id_column is None:
            raise ValueError("`response_id_column` is required.")

        if rule_name is not None and rule_name_column is not None:
            raise ValueError(
                "Pass either `rule_name` (constant) or `rule_name_column` (per-row), not both."
            )

        for arg_name, col_name in [
            ("message_column", message_column),
            ("response_id_column", response_id_column),
            ("case_id_column", case_id_column),
            ("variable_name_column", variable_name_column),
            ("collection_instance_id_column", collection_instance_id_column),
            ("rule_name_column", rule_name_column),
        ]:
            if col_name is not None and col_name not in df.columns:
                raise ValueError(
                    f"Column {col_name!r} (passed as {arg_name}) not in "
                    f"DataFrame. Available columns: {df.columns}"
                )

        row_count = self._validate_dataframe_size(df)
        if row_count == 0:
            return 0

        # One timestamp per call — same reasoning as ExceptionLogger.log_dataframe.
        timestamp = datetime.now(timezone.utc)

        rows = df.collect()
        for row in rows:
            row_dict = row.asDict()
            collection_instance_id = (
                row_dict[collection_instance_id_column] 
                if collection_instance_id_column 
                else self._context.collection_instance_id
            )

            record = self._build_record(
                event_type=event_type,
                message=( row_dict[message_column] if message_column else message ),
                rule_name=( row_dict[rule_name_column] if rule_name_column else rule_name ),
                response_id=row_dict[response_id_column],
                case_id=( row_dict[case_id_column] if case_id_column else None ),
                collection_instance_id=collection_instance_id,
                variable_name=(row_dict[variable_name_column] if variable_name_column else variable_name),
                timestamp=timestamp,
            )
            self._add_to_buffer(record)

        return row_count


    # ────────────────────────────────────────────────────────
    # Internal — record assembly
    # ────────────────────────────────────────────────────────

    def _build_record(
        self,
        *,
        event_type: str,
        message: str,
        rule_name: Optional[str],
        response_id: Optional[str],
        case_id: Optional[str],
        collection_instance_id: Optional[str],
        variable_name: Optional[str],
        timestamp: datetime,
    ) -> dict:
        """
        Assemble one Delta-ready record dict. Pure function — no side effects.

        id and timestamp are framework-managed — both
        auto-generated, never accepted from public callers.
        """
        
        fields = self._context_fields()
        fields["collection_instance_id"] = collection_instance_id

        return {
            **fields,
            "id": str(uuid.uuid4()),
            "event_type": event_type,
            "rule_name": rule_name,
            "message": message,
            "response_id": response_id,
            "case_id": case_id,
            "variable_name": variable_name,
            "created_timestamp_utc": timestamp,
        }





