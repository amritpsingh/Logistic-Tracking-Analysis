"""
ExceptionLogger — structured writer for Data Contract Technical Validation
failures into the exceptions Delta table.

Inherits from BaseLogger for buffering, flushing, context-manager lifecycle,
and table-contract validation. Adds the exception-specific surface:
    * The exceptions Delta schema.
    * Registry lookup to resolve rule names → governance metadata.
    * Public APIs: log(), log_many(), and log_dataframe().
    * for_task() factory that wires registry + context + table path.

Privacy / governance notes:
    * Raw observed values are NOT logged (PIA requirement).
    * `expected` may be supplied to assist message generation but is not stored
      as a dedicated column.

Caller-facing use-case:

    from utils.logger import ExceptionLogger

    with ExceptionLogger.for_task(
        spark=spark,
        collection_instance_id="2027-CAS-001",
        source_table="socpophousdata1_dev.social_census_parsed.individual",
        target_table="socpophousdata1_dev.social_census_validated.individual",
    ) as logger:
        logger.log(
            rule="invalid_date_format",
            event_type="DATACONTRACTVALIDATION",
            variable_name="i_submitted_date_time",
            expected="yyyy-mm-dd",
            response_id="P123456789",
        )


The context manager flushes on exit (including when the block exits via
an exception), so buffered records are never lost silently.
"""

from __future__ import annotations

import json
import uuid
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Iterable, Optional, Union

from pyspark.sql import SparkSession
from pyspark.sql.types import (
    BooleanType,
    StringType,
    StructField,
    StructType,
    TimestampType,
)

from .base_logger import BaseLogger
from .context import build_run_context
from .registry import (
    ErrorCodeRegistry,
    ResolvedCode,
    load_registry,
)
from .violation import Violation
from .table_resolver import ensure_logger_widgets, resolve_log_table_path


# Default exceptions Delta table. Override per-task via the ``log_table_path``
# argument to for_task(), or globally via the environment variable below.
# TODO: resolve through CollectionConfig.get_table_path() once the logs
# steady_state is registered there.
_LOG_TABLE_ENV_VAR = "CENSUS_EXCEPTION_LOG_TABLE"

_DEFAULT_BATCH_SIZE = 10000


def _to_loggable(value: Any) -> Optional[str]:
    """
    Convert an `expected` value into a readable string for message generation.

    Used only for constructing human-readable messages (no expected/observed columns
    are stored in the exceptions table).

    Conversion rules:
        * None -> None
        * primitives -> str(value)
        * structures -> JSON-encode via json.dumps(value)

    This ensures complex expected shapes (lists/dicts) render consistently in messages.
    """

    if value is None:
        return None
    elif isinstance(value, (bool, int, float, str)):
        return str(value)
    # Lists, dicts, tuples, etc. - JSON -encode so they round trip cleanly.
    return json.dumps(value, default=str)



class ExceptionLogger(BaseLogger):
