        collection_instance_id: Optional[str] = None,
        task_key: Optional[str] = None,
        source_table: Optional[str] = None,
        target_table: Optional[str] = None,
        log_table_path: Optional[str] = None,
        batch_size: int = _DEFAULT_BATCH_SIZE,
    ) -> "EventLogger":
        """
        Build a fully-configured EventLogger for a single task.

        The resulting logger is a context manager — use it inside a ``with`` block.

        Args:
            spark: Active SparkSession.
            collection_instance_id: Optional default collection instance for the task. 
