"""
EventLogger — structured writer for observation events into the events Delta table.

Writes non-fatal, informational events during processing (coding, MI_fix, edit, imputation, validation). 
Unlike ExceptionLogger, there's no registry — event_type and rule_name are free-text strings provided by the caller.

Inherits from BaseLogger for buffering, flushing, context-manager lifecycle, and table-contract validation.

Caller-facing use-case:

    from utils.logger import EventLogger

    with EventLogger.for_task(
        spark=spark,
        collection_instance_id="2027-CAS-001",
        source_table="socpophousdata1_dev.social_census_parsed.individual",
        target_table="socpophousdata1_dev.social_census_classified.individual",
    ) as logger:
        logger.log(
            event_type="coding",
            message="Applied ethnic group coding rules successfully",
            rule_name="ethnic_group_coding_v1",
            response_id="P12345",
            case_id="500Mp00000d56UCIAY",
            variable_name="ethnic_group",
        )

"""

from __future__ import annotations

import uuid
from datetime import datetime, timezone
from typing import Optional

from pyspark.sql import SparkSession
from pyspark.sql.types import (
    StringType,
    StructField,
    StructType,
    TimestampType,
)

from .base_logger import BaseLogger
from .context import RunContext, build_run_context
from .table_resolver import ensure_logger_widgets, resolve_log_table_path


# Default events Delta table. Override per-task via the ``log_table_path``
# argument to for_task(), or globally via the environment variable below.
_LOG_TABLE_ENV_VAR = "CENSUS_EVENT_LOG_TABLE"

_DEFAULT_BATCH_SIZE = 10000


class EventLogger(BaseLogger):
    """
    Buffered writer for the ``social_census_logs.events`` Delta table.

    Not thread-safe. One instance per task — construct via
    :meth:`EventLogger.for_task`.
    """

    # Schema mirrors the spec's events table. Shares most columns with
    # ExceptionLogger but lacks the governance fields (validation_level,
    # error_code, severity, is_blocking, stack_trace) and has a free-text
    # ``rule_name`` in their place.
    _SCHEMA: StructType = StructType([
        StructField("id", StringType(), False),
        StructField("run_id", StringType(), False),
        StructField("task_key", StringType(), False),
        StructField("source_table", StringType(), True),
        StructField("target_table", StringType(), True),
        StructField("event_type", StringType(), False),
        StructField("rule_name", StringType(), True),
        StructField("message", StringType(), True),
        StructField("response_id", StringType(), True),
        StructField("case_id", StringType(), True),
        StructField("collection_instance_id", StringType(), True),
        StructField("variable_name", StringType(), True),
        StructField("created_timestamp_utc", TimestampType(), False),
    ])

    @property
    def _schema(self) -> StructType:
        return self._SCHEMA

    # ────────────────────────────────────────────────────────
    # Constructor
    # ────────────────────────────────────────────────────────

    def __init__(
        self,
        spark: SparkSession,
