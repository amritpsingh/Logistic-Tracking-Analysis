from __future__ import annotations

import os
from typing import Optional, Union

from config_models.collection_config import Collection, CollectionConfig


DEFAULT_TARGET = "dev"
DEFAULT_COLLECTION = Collection.social_census.value


def _get_dbutils():
    """
    Return Databricks dbutils when available, otherwise None.

    This keeps the logger usable in:
      - Databricks notebooks
      - Databricks Jobs
      - local/unit-test contexts where dbutils is unavailable
    """
    try:
        from databricks.sdk.runtime import dbutils  # type: ignore[import-not-found]
        return dbutils
    except Exception:
        return None


def _get_widget_value(name: str) -> Optional[str]:
    """
    Safely read a Databricks widget value.

    Returns None when:
      - not running in Databricks
      - dbutils is unavailable
      - widget does not exist
      - widget value is blank
    """
    dbutils = _get_dbutils()
    if dbutils is None:
        return None

    try:
        value = dbutils.widgets.get(name)
    except Exception:
        return None

    if value is None or str(value).strip() == "":
        return None

    return str(value).strip()


def _create_widget_if_missing(name: str, default_value: str) -> None:
    """
    Create a Databricks text widget if it does not already exist.

    If the widget already exists, this function leaves it unchanged.
    This is important for Databricks Jobs, where job parameters are already
    materialised as widgets before notebook code runs.
    """
    dbutils = _get_dbutils()
    if dbutils is None:
        return

    try:
        # If this succeeds, widget already exists. Do not overwrite it.
        dbutils.widgets.get(name)
        return
    except Exception:
        pass

    try:
        dbutils.widgets.text(name, default_value)
    except Exception:
        # Do not make widget creation fatal. The logger can still resolve via
        # environment variables or defaults in non-notebook contexts.
        return


def ensure_logger_widgets() -> None:
    """
    Ensure standard logger widgets exist.

    This mirrors the behaviour of the parsing notebooks/settings module:
      - target defaults to dev
      - collection defaults to social_census

    Called by logger factories so users see the same widgets when using
    ExceptionLogger/EventLogger in notebooks.
    """
    _create_widget_if_missing("target", DEFAULT_TARGET)
    _create_widget_if_missing("collection", DEFAULT_COLLECTION)


def _coerce_collection(collection: Union[str, Collection]) -> Collection:
    """
    Convert a collection value into a Collection enum.

    Supports:
      - Collection.social_census
      - "social_census"
      - "config_test_survey"
      - "census_strawman"
    """
    if isinstance(collection, Collection):
        return collection

    try:
        return Collection(collection)
    except ValueError:
        try:
            return Collection[collection]
        except KeyError:
            valid = ", ".join(c.value for c in Collection)
            raise ValueError(
                f"Invalid collection {collection!r}. Valid values are: {valid}"
            ) from None


def resolve_target() -> str:
    """
    Resolve target environment for logger table path resolution.

    Resolution order:
      1. Databricks widget: target
      2. Databricks widget: Target
      3. Environment variable: CENSUS_TARGET
      4. Default: dev
    """
    ensure_logger_widgets()

    return (
        _get_widget_value("target")
        or _get_widget_value("Target")
        or os.environ.get("CENSUS_TARGET")
        or DEFAULT_TARGET
    )


def resolve_collection() -> Collection:
    """
    Resolve collection config namespace for logger table path resolution.

    Resolution order:
      1. Databricks widget: collection
      2. Databricks widget: Collection
      3. Environment variable: CENSUS_COLLECTION
      4. Default: social_census
    """
    ensure_logger_widgets()

    resolved = (
        _get_widget_value("collection")
        or _get_widget_value("Collection")
        or os.environ.get("CENSUS_COLLECTION")
        or DEFAULT_COLLECTION
    )

    return _coerce_collection(resolved)


def resolve_log_table_path(
    *,
    dataset: str,
    explicit_table_path: Optional[str] = None,
    env_var_name: Optional[str] = None,
    widget_name: Optional[str] = None,
) -> str:
    """
    Resolve a logger Delta table path dynamically.

    Resolution order:
      1. explicit_table_path argument
      2. Databricks widget override, if widget_name provided
      3. environment variable override, if env_var_name provided
      4. CollectionConfig(collection, target).get_table_path(dataset, "logs")

    Note:
      Standard widgets target/collection are created before resolving anything,
      even when explicit_table_path is supplied. This gives notebooks the same
      widget experience as parsing notebooks.
    """
    ensure_logger_widgets()

    if explicit_table_path:
        return explicit_table_path

    if widget_name:
        widget_value = _get_widget_value(widget_name)
        if widget_value:
            return widget_value

    if env_var_name:
        env_value = os.environ.get(env_var_name)
        if env_value:
            return env_value

    target = resolve_target()
    collection = resolve_collection()

    return CollectionConfig(
        collection=collection,
        environment=target,
    ).get_table_path(
        dataset=dataset,
        steady_state="logs",
    )






