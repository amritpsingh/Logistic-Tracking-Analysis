"""
Per-run contextual metadata shared across log records of a single task.

A RunContext is built once at task start and threaded into logger calls.
It answers: which run, which task within the run, which source/target tables,
and a default collection instance identifier.

Notes on current logging architecture:
- `run_id` is written to all log tables and is the join key across pipeline logs.
- `job_id` is resolved here when running under Databricks Jobs, but is not
  emitted into the events/exceptions log tables. It lives in the pipeline log
  table and can be joined via `run_id`.
- `collection_instance_id` is a default value for the task; DataFrame-based
  logging may override it per row via `collection_instance_id_column`.
"""

import logging
import uuid
from dataclasses import dataclass
from functools import lru_cache
from typing import Optional

logger = logging.getLogger(__name__)


# ─────────────────────────────────────────────
# Public types
# ─────────────────────────────────────────────

@dataclass(frozen=True)
class RunContext:
    """
    Immutable context for a single pipeline task execution.

    Frozen so it can be safely shared across threads and cannot drift mid-execution.

    - `run_id` and `task_key` identify the task execution.
    - `job_id` is resolved for pipeline-level logging and correlation, but is not
      written to events/exceptions tables (join via `run_id` if needed).
    - `collection_instance_id` is a default; DataFrame-based logging may override
      it per row when required.
    """

    run_id: str
    job_id: str = "interactive"
    task_key: str = "unknown"
    collection_instance_id: Optional[str] = None
    source_table: Optional[str] = None
    target_table: Optional[str] = None


# ─────────────────────────────────────────────
# Sentinels
# ─────────────────────────────────────────────

# Used when we can't read the real value from Databricks — puts a named,
# queryable placeholder into the logs instead of None or a random UUID.
_INTERACTIVE_JOB_ID = "interactive"
_UNKNOWN_TASK_KEY = "unknown"


# ─────────────────────────────────────────────
# Public API
# ─────────────────────────────────────────────

def build_run_context(
    collection_instance_id: Optional[str],
    *,
    task_key: Optional[str] = None,
    source_table: Optional[str] = None,
    target_table: Optional[str] = None,
) -> RunContext:
    """
    Build a RunContext, auto-resolving identity fields from Databricks.

    Identity resolution (run_id, job_id, task_key) happens in this order:

        1. Databricks Job context (the authoritative source when running
           under a Job). Pulls the task_key directly from the bundle YAML.
        2. Cached fallback (interactive notebook, pytest, local REPL). All
           callers in the same process share the same fallback run_id so
           logs across multiple loggers can be correlated.

    Callers can override ``task_key`` — useful when a single Databricks
    task represents multiple logical steps (e.g. "validate" then "write"),
    or in unit tests that need a known value without a live Databricks
    context.

    Using the Databricks Job run_id (when available) allows log records
    to join against system tables like ``system.lakeflow.job_run_timeline``
    without any bridging metadata.

    Args:
        collection_instance_id: Sub-operation the data relates to. 
        task_key: Optional override for the task key. Defaults to the
            value the Databricks Job passes in via the notebook context,
            falling back to ``"unknown"`` for interactive runs.
        source_table: Fully-qualified upstream table, if any.
        target_table: Fully-qualified downstream table, if any.

    Note:
        The ``*`` in the signature marks every argument after it as
        keyword-only. Callers must write ``task_key="x"``, not a bare
        positional argument. This prevents bugs where parameters get
        silently reordered.
    """
    databricks = _read_databricks_context()

    if databricks is not None:
        run_id = databricks.run_id
        job_id = databricks.job_id
        resolved_task_key = task_key or databricks.task_key or _UNKNOWN_TASK_KEY
    else:
        run_id = _cached_fallback_run_id()
        job_id = _INTERACTIVE_JOB_ID
        resolved_task_key = task_key or _UNKNOWN_TASK_KEY

    return RunContext(
        run_id=run_id,
        job_id=job_id,
        task_key=resolved_task_key,
        collection_instance_id=collection_instance_id,
        source_table=source_table,
        target_table=target_table,
    )


# ─────────────────────────────────────────────
# Internals
# ─────────────────────────────────────────────

@dataclass(frozen=True)
class _DatabricksContext:
    """
    Databricks notebook context.
    """
    run_id: str
    job_id: str
    task_key: Optional[str]  # Optional because some Job configurations omit it


def _read_databricks_context() -> Optional[_DatabricksContext]:
    """
    Return the Databricks notebook context if running under a Job, else None.

    Read all three fields (run_id, job_id, task_key) in one Databricks
    round-trip because each ``ctx.xxx()`` call goes through the Py4J bridge
    to the JVM and has non-trivial overhead. Batching saves three calls.
    """
    try:
        from databricks.sdk.runtime import dbutils  # type: ignore[import-not-found]

        ctx = dbutils.notebook.entry_point.getDbutils().notebook().getContext()

        # These return scala.Option objects — use .isDefined() to check
        # before .get(). Calling .get() on an empty Option raises.
        job_id_opt = ctx.jobId()
        run_id_opt = ctx.currentRunId()
        task_key_opt = ctx.taskKey()

        # run_id and job_id together tell us "we're in a Job." task_key
        # alone isn't a strong enough signal — some workflows (e.g.
        # one-off notebook runs triggered manually) set task_key but not run_id.
        if not (job_id_opt.isDefined() and run_id_opt.isDefined()):
            return None

        return _DatabricksContext(
            run_id=str(run_id_opt.get()),
            job_id=str(job_id_opt.get()),
            task_key=str(task_key_opt.get()) if task_key_opt.isDefined() else None,
        )
    except Exception as exc:  # noqa: BLE001 — any failure means we're not in a Job
        logger.debug("Databricks job context unavailable: %s", exc)
        return None


@lru_cache(maxsize=1)
def _cached_fallback_run_id() -> str:
    """
    Generate a single UUID and remember it for the rest of the process.

    ``@lru_cache(maxsize=1)`` decorates this function so the first call
    computes a fresh UUID and every subsequent call returns the same
    cached string. This guarantees two loggers built in the
    same interactive notebook share a run_id.

    Tests that need a fresh value across test cases should call
    ``_cached_fallback_run_id.cache_clear()`` in a fixture.
    """
    return str(uuid.uuid4())







