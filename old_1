        if rule is not None and rule_column is not None:
            raise ValueError(
                "Pass either `rule` (constant) or `rule_column` (per-row), not both."
            )

        # message and message_column are mutually exclusive, but both may be omitted
        # because _build_record() can auto-generate a default message.
        if message is not None and message_column is not None:
            raise ValueError(
                "Pass either `message` (constant) or `message_column` (per-row), not both."
            )

        if variable_name is not None and variable_name_column is not None:
            raise ValueError(
                "Pass either `variable_name` (constant) or `variable_name_column` (per-row), not both."
            )

        if expected is not None and expected_column is not None:
            raise ValueError(
                "Pass either `expected` (constant) or `expected_column` (per-row), not both."
            )

        if response_id_column is None:
            raise ValueError("`response_id_column` is required.")

        # Validate that every named column exists in the DataFrame.
        for arg_name, col_name in [
            ("rule_column", rule_column),
            ("message_column", message_column),
            ("response_id_column", response_id_column),
            ("case_id_column", case_id_column),
            ("variable_name_column", variable_name_column),
            ("expected_column", expected_column),
            ("collection_instance_id_column", collection_instance_id_column),
        ]:
            if col_name is not None and col_name not in df.columns:
                raise ValueError(
                    f"Column {col_name!r} (passed as {arg_name}) not in "
                    f"DataFrame. Available columns: {df.columns}"
                )

        row_count = self._validate_dataframe_size(df)
        if row_count == 0:
            return 0

        # One timestamp per call. All rows logged together share it.
        timestamp = datetime.now(timezone.utc)

        # Cache resolved rules so repeated per-row rule values don't keep hitting the registry.
        resolved_cache: dict[str, ResolvedCode] = {}

        rows = df.collect()
        for row in rows:
            row_dict = row.asDict()

            rule_value = row_dict[rule_column] if rule_column else rule
            expected_value = row_dict[expected_column] if expected_column else expected
            collection_instance_id = (
                row_dict[collection_instance_id_column]
                if collection_instance_id_column
                else self._context.collection_instance_id
            )

            # Resolve governance metadata, caching repeated rule lookups.
            if rule_value not in resolved_cache:
                resolved_cache[rule_value] = self._registry.resolve(rule_value)
            resolved = resolved_cache[rule_value]

            record = self._build_record(
                resolved=resolved,
                event_type=event_type,
                rule=rule_value,
                variable_name=(
                    row_dict[variable_name_column]
                    if variable_name_column
                    else variable_name
                ),
                expected=expected_value,
                response_id=row_dict[response_id_column],
                case_id=(row_dict[case_id_column] if case_id_column else None),
                collection_instance_id=collection_instance_id,
                message=(row_dict[message_column] if message_column else message),
                stack_trace=stack_trace,
                timestamp=timestamp,
            )
            self._add_to_buffer(record)

        return row_count



    # ────────────────────────────────────────────────────────
    # Internal — record assembly
    # ────────────────────────────────────────────────────────

    def _build_record(
        self,
        *,
        resolved: ResolvedCode,
        event_type: str,
        rule: str,
        variable_name: Optional[str],
        expected: Any,
        response_id: Optional[str],
        case_id: Optional[str],
        collection_instance_id: Optional[str],
        message: Optional[str],
        stack_trace: Optional[str],
        timestamp: datetime,
    ) -> dict:
        """
        Assemble one Delta-ready exception record dict. Pure function — no side effects.

        Notes:
            - `expected` is used only for message generation and is NOT stored as a column.
            - `collection_instance_id` is passed explicitly so DataFrame-based logging can
            override the context value per row.
            - `id` and `created_timestamp_utc` are framework-managed.
        """

        expected_str = _to_loggable(expected)

        if message is None:
            if expected_str is not None:
                message = f"Rule '{rule}' failed. Expected={expected_str!r}"
            else:
                message = f"Rule '{rule}' failed."

        fields = self._context_fields()  # run_id, task_key, source_table, target_table, collection_instance_id
        fields["collection_instance_id"] = collection_instance_id

        return {
            **fields,
            "id": str(uuid.uuid4()),
            "validation_level": resolved.validation_level.value,
            "event_type": event_type,
            "error_code": resolved.error_code,
            "severity": resolved.severity.value,
            "message": message,
            "response_id": response_id,
            "case_id": case_id,
            "variable_name": variable_name,
            "is_blocking": resolved.is_blocking,
            "stack_trace": stack_trace,
            "created_timestamp_utc": timestamp,
        }





