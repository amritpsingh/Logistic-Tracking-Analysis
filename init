I got one update is that i have create a schema yaml files for all 3 log tables as my team is developing a separate module that will  read these schema yaml files and create log delta tables in databricks based on yaml files. should we use this yaml files in this logger code for reading schema?

events.yml

table:
  name: events
  dataset: events
  steady_state: logs
  comment: Non-fatal observation events captured during Census processing.
  properties:
    delta.enableChangeDataFeed: "false"

columns:
  - name: id
    type: string
    nullable: false
    comment: Unique identifier for the event log row.

  - name: run_id
    type: string
    nullable: false
    comment: Pipeline or Databricks job run identifier used to join to pipeline_run.

  - name: task_key
    type: string
    nullable: false
    comment: Databricks task key or logical task name that produced the event.

  - name: source_table
    type: string
    nullable: true
    comment: Source table for the logical processing step.

  - name: target_table
    type: string
    nullable: true
    comment: Target table for the logical processing step.

  - name: event_type
    type: string
    nullable: false
    comment: Event category, such as parsing, coding, edit, imputation, or validation.

  - name: rule_name
    type: string
    nullable: true
    comment: Optional rule, transformation, or processing rule name associated with the event.

  - name: message
    type: string
    nullable: true
    comment: Human-readable event message.

  - name: response_id
    type: string
    nullable: true
    comment: Optional response identifier associated with the event.

  - name: case_id
    type: string
    nullable: true
    comment: Optional case identifier associated with the event.

  - name: collection_instance_id
    type: string
    nullable: true
    comment: Optional collection instance identifier associated with the event.

  - name: variable_name
    type: string
    nullable: true
    comment: Optional variable associated with the event.

  - name: created_timestamp_utc
    type: timestamp
    nullable: false
    comment: UTC timestamp when the event log row was created.






exceptions.yml

table:
  name: exceptions
  dataset: exceptions
  steady_state: logs
  comment: Data contract validation failures and technical exceptions captured during Census processing.
  properties:
    delta.enableChangeDataFeed: "false"

columns:
  - name: id
    type: string
    nullable: false
    comment: Unique identifier for the exception log row.

  - name: run_id
    type: string
    nullable: false
    comment: Pipeline or Databricks job run identifier used to join to pipeline_run.

  - name: task_key
    type: string
    nullable: false
    comment: Databricks task key or logical task name that produced the exception.

  - name: source_table
    type: string
    nullable: true
    comment: Source table for the logical processing step.

  - name: target_table
    type: string
    nullable: true
    comment: Target table for the logical processing step.

  - name: validation_level
    type: string
    nullable: false
    comment: Validation level resolved from the error code registry, such as FILE, RECORD, FIELD, or VALUE.

  - name: event_type
    type: string
    nullable: false
    comment: Exception event category, such as PARSING or DATACONTRACTVALIDATION.

  - name: error_code
    type: string
    nullable: false
    comment: Governance error code resolved from the error code registry.

  - name: severity
    type: string
    nullable: false
    comment: Severity resolved from the error code registry, such as ERROR, WARNING, or INFO.

  - name: message
    type: string
    nullable: true
    comment: Human-readable exception or validation failure message.

  - name: response_id
    type: string
    nullable: true
    comment: Optional response identifier associated with the exception.

  - name: case_id
    type: string
    nullable: true
    comment: Optional case identifier associated with the exception.

  - name: collection_instance_id
    type: string
    nullable: true
    comment: Optional collection instance identifier associated with the exception.

  - name: variable_name
    type: string
    nullable: true
    comment: Optional variable associated with the exception or validation failure.

  - name: is_blocking
    type: boolean
    nullable: false
    comment: Indicates whether the exception or validation failure blocks processing.

  - name: stack_trace
    type: string
    nullable: true
    comment: Optional stack trace for technical or unhandled processing errors.

  - name: created_timestamp_utc
    type: timestamp
    nullable: false
    comment: UTC timestamp when the exception log row was created.




pipeline_run.yml


table:
  name: pipeline_run
  dataset: pipeline_run
  steady_state: logs
  comment: One final-status control-plane record per Census pipeline or Databricks job run.
  properties:
    delta.enableChangeDataFeed: "false"

columns:
  - name: run_id
    type: string
    nullable: false
    comment: Pipeline or Databricks job run identifier. Primary correlation key for events and exceptions.

  - name: job_id
    type: string
    nullable: true
    comment: Databricks job identifier when available.

  - name: trigger_type
    type: string
    nullable: true
    comment: Trigger type for the run, such as manual, scheduled, or table update.

  - name: start_time
    type: timestamp
    nullable: true
    comment: Pipeline or job run start timestamp, normally supplied from Databricks job metadata.

  - name: end_time
    type: timestamp
    nullable: true
    comment: Pipeline or job run end timestamp, supplied by caller or generated at final logging time.

  - name: status
    type: string
    nullable: false
    comment: Final caller-supplied run status, such as SUCCEEDED or FAILED.

  - name: parent_run_id
    type: string
    nullable: true
    comment: Optional parent workflow or pipeline run identifier.

  - name: record_count
    type: bigint
    nullable: true
    comment: Optional caller-supplied record count for the pipeline run.

  - name: created_timestamp_utc
    type: timestamp
    nullable: false
    comment: UTC timestamp when the pipeline_run log row was created.
