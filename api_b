"""
Runtime interface for the error code registry.

- ErrorCodeRegistry - runtime lookup class
- ResolvedCode - frozen bundle returned by registry.resolve()
- load_registry - loads + validates YAML, cached per process
- RegistryLoadError - raised on any failure to load/validate YAML
"""

from dataclasses import dataclass
from functools import lru_cache
from pathlib import Path
from typing import Iterable, Union

import yaml
from pydantic import ValidationError

from .schema import (
    ErrorCodeRegistrySchema,
    Severity,
    ValidationLevel,
)


_MODULE_DIR = Path(__file__).parent
DEFAULT_REGISTRY_PATH: Path = _MODULE_DIR / "config" / "error_codes.yml"


class RegistryLoadError(Exception):
    """
    Raised when there is an error loading or validating the registry YAML.
    """


@dataclass(frozen=True)
class ResolvedCode:
    """
    A resolved error code, with all the information needed to process it.
    """

    error_code: str
    validation_level: ValidationLevel
    severity: Severity
    is_blocking: bool


class ErrorCodeRegistry:
    """
    Runtime interface for looking up validation semantics.

    Resolve a validator-facing rule name into a governance bundle:

        resolved = registry.resolve("invalid_date_format")
        resolved.error_code
        resolved.validation_level
        resolved.severity
        resolved.is_blocking
    """

    def __init__(self, schema: ErrorCodeRegistrySchema):
        self._rules = schema.validation_rules
        self._codes = schema.error_codes

    def resolve(self, rule: str) -> ResolvedCode:
        """
        Resolve a validator-facing rule name into governance metadata.

        Raises:
            KeyError: if the rule is not found in the registry.
        """
        try:
            rule_def = self._rules[rule]
        except KeyError:
            raise KeyError(
                f"Unknown validation rule: {rule!r}. "
                f"Check registry YAML or use ErrorCodeRegistry.known_rules()"
            ) from None

        code_def = self._codes[rule_def.error_code]

        return ResolvedCode(
            error_code=rule_def.error_code,
            validation_level=code_def.validation_level,
            severity=code_def.severity,
            is_blocking=code_def.blocking,
        )

    def resolve_many(self, rules: Iterable[str]) -> dict[str, ResolvedCode]:
        """
        Resolve many rule names into governance metadata.

        Duplicate rule names are resolved once.

        Args:
            rules: Iterable of validation rule names.

        Returns:
            Dictionary keyed by rule name.

        Raises:
            KeyError: if any rule is unknown.
        """
        unique_rules = sorted(set(rules))

        return {
            rule: self.resolve(rule)
            for rule in unique_rules
        }

    def to_lookup_rows(self, rules: Iterable[str]) -> list[tuple]:
        """
        Resolve rule names into Spark lookup rows.

        This is used by ExceptionLogger.log_dataframe() when each row can
        carry a different rule value.

        Returns rows shaped as:
            (
                rule,
                error_code,
                validation_level,
                severity,
                is_blocking,
            )
        """
        resolved_by_rule = self.resolve_many(rules)

        return [
            (
                rule,
                resolved.error_code,
                resolved.validation_level.value,
                resolved.severity.value,
                resolved.is_blocking,
            )
            for rule, resolved in resolved_by_rule.items()
        ]

    def known_rules(self) -> list[str]:
        """Return all registered validation rule names."""
        return sorted(self._rules.keys())


@lru_cache(maxsize=4)
def load_registry(registry_path: Union[str, Path, None] = None) -> ErrorCodeRegistry:
    """
    Load and validate the error code registry YAML, then wrap it in a runtime
    ErrorCodeRegistry.

    Cached per process. The cache is keyed on the path.

    Args:
        registry_path: Path to the registry YAML. Defaults to
            config/error_codes.yml in the module directory.

    Raises:
        RegistryLoadError: on file I/O, YAML parse, or schema validation failure.
    """
    path = Path(registry_path) if registry_path is not None else DEFAULT_REGISTRY_PATH

    if not path.exists():
        raise RegistryLoadError(f"Error code registry file not found: {path}")

    try:
        with path.open("r") as file:
            raw = yaml.safe_load(file)
    except yaml.YAMLError as exc:
        raise RegistryLoadError(f"Malformed YAML at {path}: {exc}") from exc
    except OSError as exc:
        raise RegistryLoadError(f"Unable to read {path}: {exc}") from exc

    if raw is None:
        raise RegistryLoadError(f"Empty YAML file: {path}")

    try:
        schema = ErrorCodeRegistrySchema(**raw)
    except ValidationError as exc:
        raise RegistryLoadError(
            f"Invalid error code registry at {path}: {exc}"
        ) from exc

    return ErrorCodeRegistry(schema)



