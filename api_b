"""
The Violation dataclass — a single validation failure observation.

The registry resolves ``rule`` into the governance fields (error_code, validation_level, severity, is_blocking). 
The caller shares: they report WHAT failed and WHAT the values were. 
The logger owns HOW the system classifies it.
"""

from dataclasses import dataclass
from typing import Any, Optional


@dataclass(frozen=True)
class Violation:
    """
    A single validation failure observation.

    Attributes:
        rule: Registered validation rule name (must exist in the registry
            YAML). Determines error_code, validation_level, severity,
            is_blocking at log time.
        variable_name: Name of the variable that failed, if applicable. 
            None for FILE-level or RECORD-level failures where 
            the failure isn't tied to a specific variable.
        expected: What was expected. expected is used only for 
        default message generation and is not stored as a dedicated table column.
        message: Optional message for this specific violation. 
            When set, it is used as-is. When None, the logger auto-generates 
            a default ``"Rule X failed. Expected Y, observed Z."`` message.
    """

    rule: str
    variable_name: Optional[str] = None
    expected: Optional[str] = None
    message: Optional[str] = None




schema.py

"""
Pydantic schemas and enums for the error code registry

The registry enforces separation between:
- validation rules (what failed)
- error codes (how system reacts)

This module is the structural contract for the registry YAML. A change here is a breaking change to governance model.
"""

from enum import Enum
from typing import Dict, Optional

from pydantic import BaseModel, ConfigDict, model_validator


# ─────────────────────────────────────────────
# Enums
# ─────────────────────────────────────────────

class ValidationLevel(str, Enum):
    """Data contract technical validation levels"""

    FILE = "FILE"
    RECORD = "RECORD"
    FIELD = "FIELD"
    VALUE = "VALUE"


class Severity(str, Enum):
    """Severity of logged observation"""

    ERROR = "ERROR"
    WARNING = "WARNING"
    INFO = "INFO"


# ─────────────────────────────────────────────
# Error Code Definition (HOW system reacts)
# ─────────────────────────────────────────────

class ErrorCodeDefinition(BaseModel):
    """
    Governance metadata for a single error code.
    Enforces:
        - FILE / RECORD / FIELD levels must be ERROR severity and blocking
        - INFO severity must never be blocking
    """

    model_config = ConfigDict(extra="forbid")

    validation_level: ValidationLevel
    blocking: bool
    severity: Severity
    description: Optional[str] = None

    @model_validator(mode="after")
    def enforce_governance_rules(self) -> "ErrorCodeDefinition":
        
        structural_levels = {
            ValidationLevel.FILE,
            ValidationLevel.RECORD,
            ValidationLevel.FIELD,
        }

        if self.validation_level in structural_levels:
            if self.severity is not Severity.ERROR:
                raise ValueError(
                    f"{self.validation_level.value} - level errors must have"
                    f"severity ERROR (got {self.severity.value})"
                )
            if not self.blocking:
                raise ValueError(
                    f"{self.validation_level.value} - level errors must be blocking"
                )

        # INFO must never block
        if self.severity is Severity.INFO and self.blocking:
            raise ValueError("INFO severity errors cannot be blocking")

        return self


# ─────────────────────────────────────────────
# Validation Rule (WHAT failed)
# ─────────────────────────────────────────────

class ValidationRule(BaseModel):
    """A validator facing rule  that maps to exactly one error code"""

    model_config = ConfigDict(extra="forbid")

    error_code: str
    description: Optional[str] = None

# ─────────────────────────────────────────────
# Metadata
# ─────────────────────────────────────────────
class RegistryMetadata(BaseModel):
    model_config = ConfigDict(extra="forbid")

    version: str
    description: Optional[str] = None
    owner: Optional[str] = None
    approved_by: Optional[str] = None
    last_updated: Optional[str] = None


# ─────────────────────────────────────────────
# Registry Root Model
# ─────────────────────────────────────────────

class ErrorCodeRegistrySchema(BaseModel):
    """Root model for the error code registry YAML."""

    model_config = ConfigDict(extra="forbid")

    metadata: RegistryMetadata
    validation_rules: Dict[str, ValidationRule]
    error_codes: Dict[str, ErrorCodeDefinition]

    @model_validator(mode="after")
    def validate_cross_references(self) -> "ErrorCodeRegistrySchema":
        # Ensure every rule references a defined error code
        
        for rule_name, rule in self.validation_rules.items():
            if rule.error_code not in self.error_codes:
                raise ValueError(
                    f"Validation rule '{rule_name}' references "
                    f"undefined error_code '{rule.error_code}'"
                )
        return self



