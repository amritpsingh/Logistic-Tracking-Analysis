"""BaseLogger — buffered writer shared by EventLogger and ExceptionLogger.

The target Delta table must already exist (created by migration SQL). The
logger reads its schema at runtime and aligns every record to it.
"""

from __future__ import annotations

import json
import logging
from datetime import datetime, timezone
from typing import Any, List, Optional, Tuple

from pyspark.sql import Column, SparkSession, functions as F
from pyspark.sql.types import StructType

log = logging.getLogger(__name__)

# Last-resort identity when run_id/task_key are neither passed nor resolvable
# from notebook context (e.g. local pytest, interactive REPL). Surfaced as a
# WARNING, never silently. Flip the two warnings below to `raise ValueError`
# if the architect wants hard-fail in all non-job contexts.
_LOCAL_FALLBACK = "LOCAL_DEBUG"


class TableContractError(RuntimeError):
    """Raised when the target log table is missing."""


def resolve_log_column(
    df_columns: List[str],
    *,
    field: str,
    const,
    column: Optional[str],
    required: bool = False,
) -> Column:
    """Return a Spark Column for a field supplied as a constant or a df column."""
    if const is not None and column is not None:
        raise ValueError(f"Pass either `{field}` or `{field}_column`, not both.")
    if required and const is None and column is None:
        raise ValueError(f"Provide `{field}` or `{field}_column`.")
    if column is not None:
        if column not in df_columns:
            raise ValueError(f"Column {column!r} not in DataFrame: {df_columns}")
        return F.col(column)
    return F.lit(const)


def load_table_contract(
    spark: SparkSession,
    table_path: str,
    *,
    table_description: str = "Log table",
) -> Tuple[StructType, List[str], set[str]]:
    """Validate the table exists and return (schema, field_names, field_name_set)."""
    if not spark.catalog.tableExists(table_path):
        raise TableContractError(
            f"{table_description} {table_path!r} does not exist; create it via SQL script."
        )
    schema = spark.table(table_path).schema
    names = schema.fieldNames()
    return schema, names, set(names)


def align_record_to_schema(
    record: dict,
    *,
    schema_field_names: List[str],
    schema_field_name_set: set[str],
    table_path: str,
) -> dict:
    """Reject keys absent from the table, fill missing columns with None, order by schema."""
    extra = set(record) - schema_field_name_set
    if extra:
        raise ValueError(
            f"Record has field(s) not in {table_path!r}: {sorted(extra)}"
        )
    return {name: record.get(name) for name in schema_field_names}


def get_notebook_run_context() -> dict:
    """Best-effort Databricks notebook/job context reader.

    Preferred production pattern is still to pass job metadata explicitly from
    job parameters. Returns all-None values when context is unavailable (some
    access modes, local/pytest) — callers handle the fallback.
    """
    context = {
        "run_id": None,
        "job_id": None,
        "job_name": None,
        "trigger_type": None,
        "start_time": None,
        "end_time": None,
        "task_key": None,
        "task_run_id": None,
        "parent_run_id": None,
    }

    def clean(value: Any) -> Optional[str]:
        if value is None:
            return None
        value = str(value).strip()
        return value or None

    try:
        from databricks.sdk.runtime import dbutils  # type: ignore[import-not-found]

        ctx_json = dbutils.notebook.entry_point.getDbutils().notebook().getContext().toJson()
        raw = json.loads(ctx_json)
        tags = raw.get("tags", {}) or {}

        current_run_id = raw.get("currentRunId")
        if isinstance(current_run_id, dict):
            context["run_id"] = clean(current_run_id.get("id"))
        else:
            context["run_id"] = clean(current_run_id)
        context["run_id"] = (
            context["run_id"] or clean(tags.get("runId")) or clean(tags.get("jobRunId"))
        )

        context["job_id"] = clean(tags.get("jobId"))
        context["job_name"] = clean(tags.get("jobName"))
        context["task_key"] = clean(tags.get("taskKey"))
        context["task_run_id"] = clean(tags.get("idInJob"))
        context["parent_run_id"] = clean(tags.get("parentRunId"))
        context["trigger_type"] = (
            clean(tags.get("triggerType")) or clean(tags.get("jobTriggerType"))
        )

        start_ms = clean(tags.get("startTimestamp"))
        if start_ms:
            context["start_time"] = datetime.fromtimestamp(int(start_ms) / 1000, tz=timezone.utc)

    except Exception as exc:
        log.debug("Databricks notebook run context unavailable: %s", exc)

    return context


class BaseLogger:
    """Buffers structured records and appends them to a Delta log table."""

    def __init__(
        self,
        spark: SparkSession,
        table_path: str,
        batch_size: int,
        run_id: str,
        task_key: str,
    ):
        if batch_size <= 0:
            raise ValueError(f"batch_size must be > 0, got {batch_size}")

        self._run_id, self._task_key = self._resolve_identity(run_id, task_key)

        self._spark = spark
        self._table_path = table_path
        self._batch_size = batch_size
        self._buffer: List[dict] = []

        self._schema, self._schema_field_names, self._schema_field_name_set = (
            load_table_contract(spark, table_path, table_description="Log table")
        )

    @staticmethod
    def _resolve_identity(run_id, task_key) -> Tuple[str, str]:
        """Prefer passed values; only read notebook context if something is missing."""
        def clean(v):
            return str(v).strip() if v is not None and str(v).strip() else None

        run_id, task_key = clean(run_id), clean(task_key)

        if run_id and task_key:
            return run_id, task_key  # happy path — no Py4J round-trip

        ctx = get_notebook_run_context()
        run_id = run_id or clean(ctx.get("run_id"))
        task_key = task_key or clean(ctx.get("task_key"))

        if not run_id:
            log.warning("run_id unresolved; log rows tagged %r", _LOCAL_FALLBACK)
            run_id = _LOCAL_FALLBACK
        if not task_key:
            log.warning("task_key unresolved; log rows tagged %r", _LOCAL_FALLBACK)
            task_key = _LOCAL_FALLBACK

        return run_id, task_key

    def __enter__(self) -> "BaseLogger":
        return self

    def __exit__(self, exception_type, exception_value, traceback_obj) -> bool:
        try:
            self.flush()
        except Exception as flush_exc:
            if exception_value is None:
                raise
            log.error("Flush failed on exit for %s: %s", self._table_path, flush_exc)
        return False

    def flush(self) -> None:
        """Append buffered records; buffer is cleared only after a successful write."""
        if not self._buffer:
            return
        try:
            records = [self._align(r) for r in self._buffer]
            df = self._spark.createDataFrame(records, schema=self._schema)
            df.write.mode("append").format("delta").saveAsTable(self._table_path)
        except Exception as exc:
            log.warning(
                "Flush failed for %s (%d records retained): %s",
                self._table_path, len(self._buffer), exc,
            )
            raise RuntimeError(
                f"Failed to write {len(self._buffer)} record(s) to {self._table_path}"
            ) from exc
        self._buffer.clear()

    @property
    def buffer_size(self) -> int:
        return len(self._buffer)

    @property
    def table_path(self) -> str:
        return self._table_path

    @property
    def run_id(self) -> str:
        return self._run_id

    @property
    def task_key(self) -> str:
        return self._task_key

    def _add_to_buffer(self, record: dict) -> None:
        self._buffer.append(record)
        if len(self._buffer) >= self._batch_size:
            self.flush()

    def _execution_fields(self) -> dict:
        return {"run_id": self._run_id, "task_key": self._task_key}

    def _to_table_schema(self, df):
        """Reject extra columns, fill missing table columns with NULL, cast and order to schema."""
        df_cols = set(df.columns)
        extra = df_cols - self._schema_field_name_set
        if extra:
            raise ValueError(
                f"DataFrame has field(s) not in target table {self._table_path!r}: {sorted(extra)}"
            )
        return df.select(*[
            (F.col(f.name) if f.name in df_cols else F.lit(None)).cast(f.dataType).alias(f.name)
            for f in self._schema.fields
        ])

    def _align(self, record: dict) -> dict:
        return align_record_to_schema(
            record,
            schema_field_names=self._schema_field_names,
            schema_field_name_set=self._schema_field_name_set,
            table_path=self._table_path,
        )
