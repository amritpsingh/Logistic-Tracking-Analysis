"""
ExceptionLogger — writes Data Contract validation failures to the exceptions table.
"""

from __future__ import annotations

import uuid
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Iterable, Optional, Union

from pyspark.sql import functions as F

from .base_logger import BaseLogger, resolve_log_column
from .registry import load_registry
from .table_resolver import resolve_log_table_path
from .violation import Violation
from utils.props_resolver import ensure_props_widgets


_DEFAULT_BATCH_SIZE = 10000


class ExceptionLogger(BaseLogger):
    """Buffered writer for social_census_logs.exceptions. One instance per task."""

    def __init__(
        self,
        spark,
        registry,
        table_path,
        run_id: Optional[str],
        task_key: Optional[str],
        batch_size: int = _DEFAULT_BATCH_SIZE,
    ):
        super().__init__(
            spark=spark,
            table_path=table_path,
            batch_size=batch_size,
            run_id=run_id,
            task_key=task_key,
        )
        self._registry = registry

    @classmethod
    def for_task(
        cls,
        spark,
        *,
        run_id: Optional[str] = None,
        task_key: Optional[str] = None,
        log_table_path: Optional[str] = None,
        registry_path: Optional[Union[str, Path]] = None,
        batch_size: int = _DEFAULT_BATCH_SIZE,
    ) -> "ExceptionLogger":
        """
        Build an ExceptionLogger for one task execution.

        run_id and task_key should normally be passed from Databricks job
        parameters. If omitted, BaseLogger attempts to resolve them from
        Databricks notebook run context and raises if unresolved.
        """
        registry = load_registry(registry_path)

        ensure_props_widgets()

        table = resolve_log_table_path(
            dataset="exceptions",
            explicit_table_path=log_table_path,
        )

        return cls(
            spark=spark,
            registry=registry,
            table_path=table,
            run_id=run_id,
            task_key=task_key,
            batch_size=batch_size,
        )

    # ────────────────────────────────────────────────────────
    # Public API — single record
    # ────────────────────────────────────────────────────────

    def log(
        self,
        *,
        rule: str,
        event_type: str,
        source_table: Optional[str] = None,
        target_table: Optional[str] = None,
        collection_instance_id: Optional[str] = None,
        variable_name: Optional[str] = None,
        expected: Any = None,
        response_id: Optional[str] = None,
        case_id: Optional[str] = None,
        message: Optional[str] = None,
        stack_trace: Optional[str] = None,
    ) -> None:
        """Log one validation failure or technical exception."""
        self._add_to_buffer(
            self._record(
                rule=rule,
                event_type=event_type,
                source_table=source_table,
                target_table=target_table,
                collection_instance_id=collection_instance_id,
                variable_name=variable_name,
                expected=expected,
                response_id=response_id,
                case_id=case_id,
                message=message,
                stack_trace=stack_trace,
            )
        )

    # ────────────────────────────────────────────────────────
    # Public API — multiple records
    # ────────────────────────────────────────────────────────

    def log_many(
        self,
        violations: Iterable[Violation],
        *,
        event_type: str,
        source_table: Optional[str] = None,
        target_table: Optional[str] = None,
        collection_instance_id: Optional[str] = None,
        response_id: Optional[str] = None,
        case_id: Optional[str] = None,
        stack_trace: Optional[str] = None,
    ) -> None:
        """
        Log several violations sharing response_id / case_id / event_type.

        All rows from one log_many() call share the same timestamp.
        """
        timestamp = datetime.now(timezone.utc)

        for violation in violations:
            self._add_to_buffer(
                self._record(
                    rule=violation.rule,
                    event_type=event_type,
                    source_table=source_table,
                    target_table=target_table,
                    collection_instance_id=collection_instance_id,
                    variable_name=violation.variable_name,
                    expected=violation.expected,
                    response_id=response_id,
                    case_id=case_id,
                    message=violation.message,
                    stack_trace=stack_trace,
                    timestamp=timestamp,
                )
            )

    # ────────────────────────────────────────────────────────
    # Public API — DataFrame-based bulk logging
    # ────────────────────────────────────────────────────────

    def log_dataframe(
        self,
        df,
        *,
        event_type: str,
        response_id_column: str,
        rule: Optional[str] = None,
        rule_column: Optional[str] = None,
        source_table: Optional[str] = None,
        target_table: Optional[str] = None,
        variable_name: Optional[str] = None,
        variable_name_column: Optional[str] = None,
        expected: Any = None,
        expected_column: Optional[str] = None,
        case_id_column: Optional[str] = None,
        collection_instance_id: Optional[str] = None,
        collection_instance_id_column: Optional[str] = None,
        message: Optional[str] = None,
        message_column: Optional[str] = None,
        stack_trace: Optional[str] = None,
    ) -> None:
        """
        Append one exception row per DataFrame row in a single distributed write.
        """
        self.flush()

        cols = df.columns

        self._validate_log_dataframe_args(
            cols=cols,
            response_id_column=response_id_column,
            rule=rule,
            rule_column=rule_column,
            variable_name=variable_name,
            variable_name_column=variable_name_column,
            expected=expected,
            expected_column=expected_column,
            case_id_column=case_id_column,
            collection_instance_id=collection_instance_id,
            collection_instance_id_column=collection_instance_id_column,
            message=message,
            message_column=message_column,
        )

        df, rule_col, error_code, level, severity, blocking = (
            self._governance_columns(df, rule, rule_column)
        )

        out = self._build_log_dataframe_output(
            df=df,
            cols=cols,
            event_type=event_type,
            response_id_column=response_id_column,
            source_table=source_table,
            target_table=target_table,
            variable_name=variable_name,
            variable_name_column=variable_name_column,
            expected=expected,
            expected_column=expected_column,
            case_id_column=case_id_column,
            collection_instance_id=collection_instance_id,
            collection_instance_id_column=collection_instance_id_column,
            message=message,
            message_column=message_column,
            stack_trace=stack_trace,
            rule_col=rule_col,
            error_code=error_code,
            level=level,
            severity=severity,
            blocking=blocking,
        )

        self._write_dataframe(out)

    # ────────────────────────────────────────────────────────
    # DataFrame validation helpers
    # ────────────────────────────────────────────────────────

    def _validate_log_dataframe_args(
        self,
        *,
        cols: list[str],
        response_id_column: str,
        rule: Optional[str],
        rule_column: Optional[str],
        variable_name: Optional[str],
        variable_name_column: Optional[str],
        expected: Any,
        expected_column: Optional[str],
        case_id_column: Optional[str],
        collection_instance_id: Optional[str],
        collection_instance_id_column: Optional[str],
        message: Optional[str],
        message_column: Optional[str],
    ) -> None:
        """
        Validate log_dataframe arguments before Spark expressions are built.

        This keeps guard-rail errors deterministic and prevents Python from
        reaching df.select(...) before argument validation has completed.
        """
        self._validate_required_dataframe_column(
            cols=cols,
            column_name=response_id_column,
            arg_name="response_id_column",
        )

        if (rule is None) == (rule_column is None):
            raise ValueError("Provide exactly one of `rule` or `rule_column`.")

        self._validate_value_or_column(
            field="message",
            value=message,
            column=message_column,
        )

        self._validate_value_or_column(
            field="variable_name",
            value=variable_name,
            column=variable_name_column,
        )

        self._validate_value_or_column(
            field="expected",
            value=expected,
            column=expected_column,
        )

        self._validate_value_or_column(
            field="collection_instance_id",
            value=collection_instance_id,
            column=collection_instance_id_column,
        )

        self._validate_dataframe_columns(
            cols=cols,
            rule_column=rule_column,
            message_column=message_column,
            response_id_column=response_id_column,
            case_id_column=case_id_column,
            variable_name_column=variable_name_column,
            expected_column=expected_column,
            collection_instance_id_column=collection_instance_id_column,
        )

    # ────────────────────────────────────────────────────────
    # DataFrame expression builders
    # ────────────────────────────────────────────────────────

    def _build_log_dataframe_output(
        self,
        *,
        df,
        cols: list[str],
        event_type: str,
        response_id_column: str,
        source_table: Optional[str],
        target_table: Optional[str],
        variable_name: Optional[str],
        variable_name_column: Optional[str],
        expected: Any,
        expected_column: Optional[str],
        case_id_column: Optional[str],
        collection_instance_id: Optional[str],
        collection_instance_id_column: Optional[str],
        message: Optional[str],
        message_column: Optional[str],
        stack_trace: Optional[str],
        rule_col,
        error_code,
        level,
        severity,
        blocking,
    ):
        """
        Build the Spark DataFrame that matches the exceptions log shape before
        final table-schema alignment.
        """
        expected_col = resolve_log_column(
            cols,
            field="expected",
            const=expected,
            column=expected_column,
        )

        message_col = resolve_log_column(
            cols,
            field="message",
            const=message,
            column=message_column,
        )

        message_out = F.coalesce(
            message_col,
            self._default_message(rule_col, expected_col),
        )

        return df.select(
            F.expr("uuid()").alias("id"),
            F.lit(self._run_id).alias("run_id"),
            F.lit(self._task_key).alias("task_key"),
            F.lit(source_table).alias("source_table"),
            F.lit(target_table).alias("target_table"),
            level.alias("validation_level"),
            F.lit(event_type).alias("event_type"),
            error_code.alias("error_code"),
            severity.alias("severity"),
            message_out.alias("message"),
            F.col(response_id_column).alias("response_id"),
            resolve_log_column(
                cols,
                field="case_id",
                const=None,
                column=case_id_column,
            ).alias("case_id"),
            resolve_log_column(
                cols,
                field="collection_instance_id",
                const=collection_instance_id,
                column=collection_instance_id_column,
            ).alias("collection_instance_id"),
            resolve_log_column(
                cols,
                field="variable_name",
                const=variable_name,
                column=variable_name_column,
            ).alias("variable_name"),
            blocking.alias("is_blocking"),
            F.lit(stack_trace).alias("stack_trace"),
            F.current_timestamp().alias("created_timestamp_utc"),
        )

    # ────────────────────────────────────────────────────────
    # Governance resolution
    # ────────────────────────────────────────────────────────

    def _governance_columns(self, df, rule, rule_column):
        """
        Resolve rule(s) to governance columns.

        For constant rule:
            Resolve once and return literal Spark columns.

        For per-row rule_column:
            Resolve distinct rule values on the driver, build a small lookup
            DataFrame, and broadcast-join it to the source DataFrame.
        """
        if (rule is None) == (rule_column is None):
            raise ValueError("Provide exactly one of `rule` or `rule_column`.")

        if rule_column is not None:
            if rule_column not in df.columns:
                raise ValueError(f"rule_column {rule_column!r} not in {df.columns}")

            rows = []

            for rule_value in (
                row[0]
                for row in df.select(rule_column).distinct().collect()
            ):
                resolved = self._registry.resolve(rule_value)
                rows.append(
                    (
                        rule_value,
                        resolved.error_code,
                        resolved.validation_level.value,
                        resolved.severity.value,
                        resolved.is_blocking,
                    )
                )

            lookup = self._spark.createDataFrame(
                rows,
                "_gov_rule string, _gov_error_code string, _gov_level string, "
                "_gov_severity string, _gov_blocking boolean",
            )

            df = df.join(
                F.broadcast(lookup),
                F.col(rule_column) == F.col("_gov_rule"),
                "left",
            )

            return (
                df,
                F.col(rule_column),
                F.col("_gov_error_code"),
                F.col("_gov_level"),
                F.col("_gov_severity"),
                F.col("_gov_blocking"),
            )

        resolved = self._registry.resolve(rule)

        return (
            df,
            F.lit(rule),
            F.lit(resolved.error_code),
            F.lit(resolved.validation_level.value),
            F.lit(resolved.severity.value),
            F.lit(resolved.is_blocking),
        )

    @staticmethod
    def _default_message(rule_col, expected_col):
        rule_str = rule_col.cast("string")
        base = F.concat(F.lit("Rule '"), rule_str, F.lit("' failed."))
        with_expected = F.concat(
            F.lit("Rule '"),
            rule_str,
            F.lit("' failed. Expected="),
            expected_col.cast("string"),
        )
        return F.when(expected_col.isNotNull(), with_expected).otherwise(base)

    # ────────────────────────────────────────────────────────
    # Single-record assembly
    # ────────────────────────────────────────────────────────

    def _record(
        self,
        *,
        rule,
        event_type,
        source_table,
        target_table,
        collection_instance_id,
        variable_name,
        expected,
        response_id,
        case_id,
        message,
        stack_trace,
        timestamp=None,
    ) -> dict:
        resolved = self._registry.resolve(rule)

        if message is None:
            message = (
                f"Rule {rule!r} failed. Expected={expected!r}"
                if expected is not None
                else f"Rule {rule!r} failed."
            )

        timestamp = timestamp or datetime.now(timezone.utc)

        return {
            **self._execution_fields(),
            "id": str(uuid.uuid4()),
            "source_table": source_table,
            "target_table": target_table,
            "validation_level": resolved.validation_level.value,
            "event_type": event_type,
            "error_code": resolved.error_code,
            "severity": resolved.severity.value,
            "message": message,
            "response_id": response_id,
            "case_id": case_id,
            "collection_instance_id": collection_instance_id,
            "variable_name": variable_name,
            "is_blocking": resolved.is_blocking,
            "stack_trace": stack_trace,
            "created_timestamp_utc": timestamp,
        }



