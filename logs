"""
Unit tests for utils.logger.event_logger

Uses shared test doubles from tests.unit._fakes so the fake Spark surface
stays in one place across all logger test files.

Focuses on EventLogger-specific behaviour — record assembly, optional
fields, message/variable_name/rule_name shapes. Buffer, flush, and
context-manager semantics are inherited from BaseLogger and covered
exhaustively in tests/unit/test_base_logger.py.
"""

from datetime import datetime, timezone
