"""
Schema utilities shared across transformations.

Provides:
    * `build_schema` — derive the expected physical schema for a target
      table from a list of VariableConfig.
    * `find_schema_mismatches` — diff an actual table schema against an
      expected schema, returning structured per-column detail suitable
      for logging.
    * `table_exists` — check whether a table can be referenced via the
      metastore catalog.
    * `validate_schema` — assert two schemas match, raising ValueError
      with diff detail when they differ.
"""

from typing import List

from pyspark.sql import SparkSession
from pyspark.sql.types import (
    ByteType,
    IntegerType,
    LongType,
    StringType,
    StructField,
    StructType,
    TimestampType,
)
from pyspark.sql.utils import AnalysisException

from config_models.transformation_config import VariableConfig


# YAML type → Spark physical type for target-table schema construction.
_TYPE_MAP = {
    "string":    StringType(),
    "integer":   IntegerType(),
    "tinyint":   ByteType(),
    "long":      LongType(),
    "timestamp": TimestampType(),
}


def build_schema(
    output_variables: List[VariableConfig],
    *,
    use_alias: bool = True,
    include_insert_time_utc: bool = True,
) -> StructType:
    """
    Build the expected physical schema for a target table from YAML.

    Args:
        output_variables: Variable configs parsed from `output_variables`
            in the transformation YAML.
        use_alias: Use `v.alias` as the column name (matches the physical
            table). Set False to use `v.name` (matches the in-DataFrame
            names produced by `Parsing.transform`).
        include_insert_time_utc: Append the writer-added audit column.
            The default writer always adds it, so leave True when
            comparing against the physical table schema.

    Internal variables (`internal: true`) are excluded — they are not
    written to the table.

    Raises:
        ValueError: when a variable declares a type not present in the
            supported map.
    """
    fields = []
    for v in output_variables:
        if v.internal:
            continue

        col_name = v.alias if use_alias else v.name
        if v.type not in _TYPE_MAP:
            raise ValueError(
                f"Unsupported type {v.type!r} for variable {col_name!r}. "
                f"Supported: {sorted(_TYPE_MAP)}"
            )
        # `allow_blank` in YAML maps to nullable in the physical schema.
        fields.append(StructField(col_name, _TYPE_MAP[v.type], v.allow_blank))

    if include_insert_time_utc:
        fields.append(StructField("insert_time_utc", TimestampType(), False))

    return StructType(fields)


def find_schema_mismatches(*, actual: StructType, expected: StructType) -> List[dict]:
    """
    Diff `expected` against `actual`. Order-insensitive.

    Returns one dict per offending column::

        {
            "column":   "<name>",
            "kind":     "missing_in_actual" |
                        "type_mismatch" |
                        "nullability_mismatch",
            "expected": "<type or nullability>",
            "actual":   "<type or nullability>" | None,
        }

    Extra columns present in `actual` but not in `expected` are not
    flagged — target tables routinely carry audit and metadata columns
    added by other processes (hash_key, ingestion timestamps, etc.),
    and those are out of scope for the parsing contract.

    A column with both a type and a nullability difference produces two
    entries so each log row stays focused on one dimension.
    """
    actual_fields = {f.name: f for f in actual.fields}
    mismatches: List[dict] = []

    for exp in expected.fields:
        if exp.name not in actual_fields:
            mismatches.append({
                "column": exp.name,
                "kind": "missing_in_actual",
                "expected": f"{exp.dataType.simpleString()} (nullable={exp.nullable})",
                "actual": None,
            })
            continue

        act = actual_fields[exp.name]
        if act.dataType != exp.dataType:
            mismatches.append({
                "column": exp.name,
                "kind": "type_mismatch",
                "expected": exp.dataType.simpleString(),
                "actual": act.dataType.simpleString(),
            })
        if act.nullable != exp.nullable:
            mismatches.append({
                "column": exp.name,
                "kind": "nullability_mismatch",
                "expected": f"nullable={exp.nullable}",
                "actual": f"nullable={act.nullable}",
            })

    return mismatches


def table_exists(spark: SparkSession, table_path: str) -> bool:
    """
    Return True when the table can be referenced via the metastore catalog.

    Used as a precondition for schema-mismatch checks and as a gate
    before parsing — when the target table does not yet exist, parsing
    output cannot be written, so the job should fail early.
    """
    try:
        spark.table(table_path).limit(0).collect()
        return True
    except AnalysisException:
        return False


def validate_schema(df, expected_schema: StructType) -> None:
    """
    Assert that `df`'s schema matches `expected_schema`. Column order is
    ignored. Raises ValueError with the full diff when they differ.

    For column-level mismatch detail (suitable for per-column logging)
    use `find_schema_mismatches` instead.
    """
    actual = StructType(sorted(df.schema, key=lambda x: x.name))
    expected = StructType(sorted(expected_schema, key=lambda x: x.name))
    if actual != expected:
        raise ValueError(
            f"""
Schema mismatch detected!

Expected schema:
{expected}

Actual schema:
{actual}
"""
        )
