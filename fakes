"""Shared test doubles for the logger suite (single-record / flush paths only).

log_dataframe is a distributed Spark transform now — it can't be exercised
with these doubles. Its guard-rail ValueErrors fire on df.columns and ARE
testable here; its output rows are covered by the real-Spark tests.
"""

from __future__ import annotations

from pyspark.sql.types import StructType


class FakeDataFrame:
    """Records the .write.mode().format().saveAsTable() chain without writing."""

    def __init__(self, rows, schema, raise_on_save: bool = False):
        self.rows = rows
        self.schema = schema
        self.raise_on_save = raise_on_save
        self._mode = None
        self._format = None
        self.saved_to = None

    @property
    def write(self):
        return self

    def mode(self, mode):
        self._mode = mode
        return self

    def format(self, fmt):
        self._format = fmt
        return self

    def saveAsTable(self, table_path):
        if self.raise_on_save:
            raise RuntimeError("simulated Spark write failure")
        self.saved_to = table_path


class FakeCatalog:
    def __init__(self):
        self._tables: dict[str, StructType] = {}

    def register(self, table_path, schema):
        self._tables[table_path] = schema

    def tableExists(self, table_path):
        return table_path in self._tables

    def schema_for(self, table_path):
        return self._tables[table_path]


class FakeTable:
    def __init__(self, schema):
        self.schema = schema


class FakeSpark:
    """SparkSession stand-in. Carries a FakeCatalog and records every write."""

    def __init__(self, raise_on_create=False, raise_on_save=False):
        self.raise_on_create = raise_on_create
        self.raise_on_save = raise_on_save
        self.created: list[FakeDataFrame] = []
        self.catalog = FakeCatalog()

    def createDataFrame(self, rows, schema):
        if self.raise_on_create:
            raise RuntimeError("simulated createDataFrame failure")
        df = FakeDataFrame(list(rows), schema, raise_on_save=self.raise_on_save)
        self.created.append(df)
        return df

    def table(self, table_path):
        return FakeTable(self.catalog.schema_for(table_path))


def make_spark_with_table(table_path, schema, *, raise_on_create=False, raise_on_save=False):
    spark = FakeSpark(raise_on_create=raise_on_create, raise_on_save=raise_on_save)
    spark.catalog.register(table_path, schema)
    return spark


class FakeInputDataFrame:
    """Minimal df for guard-rail tests — exposes only .columns (no collect/select)."""

    def __init__(self, columns: list[str]):
        self.columns = columns
