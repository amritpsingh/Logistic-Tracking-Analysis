from __future__ import annotations

import os
from typing import Optional

from config_models.collection_config import CollectionConfig
from utils.props_resolver import (
    DEFAULT_COLLECTION,
    DEFAULT_TARGET,
    create_widget_if_missing,
    get_widget_value,
    resolve_collection,
    resolve_target,
)

def ensure_logger_widgets() -> None:
    """
    Ensure standard logger widgets exist.

    This mirrors the behaviour of the parsing notebooks/settings module:
      - target defaults to dev
      - collection defaults to social_census

    Called by logger factories so users see the same widgets when using
    ExceptionLogger/EventLogger in notebooks.
    """
    create_widget_if_missing("target", DEFAULT_TARGET)
    create_widget_if_missing("collection", DEFAULT_COLLECTION)


def resolve_log_table_path(
    *,
    dataset: str,
    explicit_table_path: Optional[str] = None,
) -> str:
    """
    Resolve a logger Delta table path.

    Resolution order:
      1. explicit_table_path argument
      2. CollectionConfig(collection, target).get_table_path(dataset, "logs")
    """
    ensure_logger_widgets()

    if explicit_table_path:
        return explicit_table_path

    target = resolve_target()
    collection = resolve_collection()

    return CollectionConfig(
        collection=collection,
        environment=target,
    ).get_table_path(
        dataset=dataset,
        steady_state="logs",
    )



