"""BaseLogger — buffered writer shared by EventLogger and ExceptionLogger.

The target Delta table must already exist (created by migration SQL). The
logger reads its schema at runtime and aligns every record to it.
"""

from __future__ import annotations

import logging
from typing import List, Optional, Tuple, Any

from pyspark.sql import Column, SparkSession, functions as F
from pyspark.sql.types import StructType

log = logging.getLogger(__name__)


class TableContractError(RuntimeError):
    """Raised when the target log table is missing."""


def resolve_log_column(
    df_columns: List[str],
    *,
    field: str,
    const,
    column: Optional[str],
    required: bool = False,
) -> Column:
    """Return a Spark Column for a field supplied as a constant or a df column."""
    if const is not None and column is not None:
        raise ValueError(f"Pass either `{field}` or `{field}_column`, not both.")
    if required and const is None and column is None:
        raise ValueError(f"Provide `{field}` or `{field}_column`.")
    if column is not None:
        if column not in df_columns:
            raise ValueError(f"Column {column!r} not in DataFrame: {df_columns}")
        return F.col(column)
    return F.lit(const)


def load_table_contract(
    spark: SparkSession,
    table_path: str,
    *,
    table_description: str = "Log table",
) -> Tuple[StructType, List[str], set[str]]:
    """
    Validate that a table exists and load its schema contract.

    Returns:
        schema, schema_field_names, schema_field_name_set
    """
    if not spark.catalog.tableExists(table_path):
        raise TableContractError(
            f"{table_description} {table_path!r} does not exist; "
            f"create it via SQL Script."
        )

    schema = spark.table(table_path).schema
    schema_field_names = schema.fieldNames()
    schema_field_name_set = set(schema_field_names)

    return schema, schema_field_names, schema_field_name_set


def align_record_to_schema(
    record: dict,
    *,
    schema_field_names: List[str],
    schema_field_name_set: set[str],
    table_path: str,
) -> dict:
    """
    Strictly align one record to a target table schema.

    Behaviour:
      - Rejects keys not present in the target table.
      - Fills missing table columns with None.
      - Orders values according to target table schema.
    """
    extra = set(record) - schema_field_name_set

    if extra:
        raise ValueError(
            f"Record has field(s) not in {table_path!r}: {sorted(extra)}"
        )

    return {
        field_name: record.get(field_name)
        for field_name in schema_field_names
    }


def get_notebook_run_context() -> dict:
    """
    Databricks notebook/job run context reader and fallback helper only.

    Notes:
        - Preferred production pattern is still to pass job metadata from
          Databricks job parameters into notebooks.
        - In some Databricks access modes, notebook context access may be
          unavailable. In that case, this function returns None values.
    """
    context = {
        "run_id": None,
        "job_id": None,
        "job_name": None,
        "trigger_type": None,
        "start_time": None,
        "end_time": None,
        "task_key": None,
        "task_run_id": None,
        "parent_run_id": None,
    }

    def clean(value: Any) -> Optional[str]:
        if value is None:
            return None
        value = str(value).strip()
        return value if value else None

    try:
        from databricks.sdk.runtime import dbutils  # type: ignore[import-not-found]

        ctx_json = dbutils.notebook.entry_point.getDbutils().notebook().getContext().toJson()
        raw_context = json.loads(ctx_json)
        tags = raw_context.get("tags", {}) or {}

        current_run_id = raw_context.get("currentRunId")
        if isinstance(current_run_id, dict):
            context["run_id"] = clean(current_run_id.get("id"))
        else:
            context["run_id"] = clean(current_run_id)

        context["run_id"] = (
            context["run_id"]
            or clean(tags.get("runId"))
            or clean(tags.get("jobRunId"))
        )

        context["job_id"] = clean(tags.get("jobId"))
        context["job_name"] = clean(tags.get("jobName"))
        context["task_key"] = clean(tags.get("taskKey"))
        context["task_run_id"] = clean(tags.get("idInJob"))
        context["parent_run_id"] = clean(tags.get("parentRunId"))

        context["trigger_type"] = (
            clean(tags.get("triggerType"))
            or clean(tags.get("jobTriggerType"))
        )

        start_timestamp_ms = clean(tags.get("startTimestamp"))
        if start_timestamp_ms:
            context["start_time"] = datetime.fromtimestamp(
                int(start_timestamp_ms) / 1000,
                tz=timezone.utc,
            )

    except Exception as exc:
        log.debug("Databricks notebook run context unavailable: %s", exc)

    return context


class BaseLogger:
    """Buffers structured records and appends them to a Delta log table."""

    def __init__(
        self,
        spark: SparkSession,
        table_path: str,
        batch_size: int,
        run_id: str,
        task_key: str,
    ):
        if batch_size <= 0:
            raise ValueError(f"batch_size must be > 0, got {batch_size}")
        
        notebook_context = get_notebook_run_context()

        self._run_id = (
            str(run_id).strip()
            if run_id is not None and str(run_id).strip()
            else notebook_context.get("run_id")
            or "LOCAL_DEBUG"
        )

        self._task_key = (
            str(task_key).strip()
            if task_key is not None and str(task_key).strip()
            else notebook_context.get("task_key")
            or "LOCAL_DEBUG"
        )

        self._spark = spark
        self._table_path = table_path
        self._batch_size = batch_size
        self._buffer: List[dict] = []

        self._schema, self._schema_field_names, self._schema_field_name_set = (
            load_table_contract(
                spark=spark,
                table_path=table_path,
                table_description="Log table",
            )
        )

    def __enter__(self) -> "BaseLogger":
        return self

    def __exit__(self, exception_type, exception_value, traceback_obj) -> bool:
        try:
            self.flush()
        except Exception as flush_exc:
            if exception_value is None:
                raise
            log.error("Flush failed on exit for %s: %s", self._table_path, flush_exc)
        return False

    def flush(self) -> None:
        """Append buffered records; the buffer is cleared only after a successful write."""
        if not self._buffer:
            return
        try:
            records = [self._align(r) for r in self._buffer]
            df = self._spark.createDataFrame(records, schema=self._schema)
            df.write.mode("append").format("delta").saveAsTable(self._table_path)
        except Exception as exc:
            log.warning(
                "Flush failed for %s (%d records retained): %s",
                self._table_path, len(self._buffer), exc,
            )
            raise RuntimeError(
                f"Failed to write {len(self._buffer)} record(s) to {self._table_path}"
            ) from exc
        self._buffer.clear()

    @property
    def buffer_size(self) -> int:
        return len(self._buffer)

    @property
    def table_path(self) -> str:
        return self._table_path

    @property
    def run_id(self) -> str:
        return self._run_id

    @property
    def task_key(self) -> str:
        return self._task_key

    def _add_to_buffer(self, record: dict) -> None:
        self._buffer.append(record)
        if len(self._buffer) >= self._batch_size:
            self.flush()

    def _execution_fields(self) -> dict:
        return {"run_id": self._run_id, "task_key": self._task_key}

    def _to_table_schema(self, df):
        """
        Strictly align a DataFrame to the target table schema.

        Behaviour:
        - Reject columns not present in the target table.
        - Fill missing target columns with NULL.
        - Cast and order columns to match the target table.
        """
        df_column_set = set(df.columns)

        extra = df_column_set - self._schema_field_name_set
        if extra:
            raise ValueError(
                f"DataFrame contains field(s) not present in target table "
                f"{self._table_path!r}: {sorted(extra)}"
            )

        aligned_cols = []

        for field in self._schema.fields:
            if field.name in df_column_set:
                aligned_cols.append(
                    F.col(field.name).cast(field.dataType).alias(field.name)
                )
            else:
                aligned_cols.append(
                    F.lit(None).cast(field.dataType).alias(field.name)
                )

        return df.select(*aligned_cols)

    def _align(self, record: dict) -> dict:
        return align_record_to_schema(
            record,
            schema_field_names=self._schema_field_names,
            schema_field_name_set=self._schema_field_name_set,
            table_path=self._table_path,
        )



