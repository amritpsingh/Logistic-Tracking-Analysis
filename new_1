base_logger.py

"""
BaseLogger — shared buffering / flushing / lifecycle for structured loggers.

This base class is intentionally table-schema-driven:
- The target Delta table must already exist.
- The logger reads the actual table schema at runtime.
- Records are strictly aligned to the table schema before writing.
- Extra record fields that do not exist in the target table raise an error.

Subclasses own their public logging API and record construction only.
"""

from __future__ import annotations

import logging
from typing import List

from pyspark.sql import SparkSession
from pyspark.sql.types import StructType

log = logging.getLogger(__name__)


class BaseLogger:
    """
    Buffered writer for structured log records into a Delta table.

    Subclasses should:
        - call super().__init__(...)
        - build record dictionaries
        - call self._add_to_buffer(record)

    The schema is loaded from the actual target Delta table at runtime.
    """

    DATAFRAME_ROW_LIMIT: int = 100000

    def __init__(
        self,
        spark: SparkSession,
        table_path: str,
        batch_size: int,
        run_id: str,
        task_key: str,
    ):
        """
        Initialise shared logger state.

        Args:
            spark: Active SparkSession.
            table_path: Fully-qualified Delta table path.
            batch_size: Records to buffer before auto-flush.
            run_id: Pipeline/job run identifier passed from notebook/job metadata.
            task_key: Databricks task key passed from notebook/job metadata.

        Raises:
            ValueError: if required inputs are missing or invalid.
            TableContractError: if target table does not exist.
        """
        if batch_size <= 0:
            raise ValueError(f"batch_size must be > 0, got {batch_size}")

        if run_id is None or str(run_id).strip() == "":
            raise ValueError("run_id is required and cannot be blank")

        if task_key is None or str(task_key).strip() == "":
            raise ValueError("task_key is required and cannot be blank")

        self._spark = spark
        self._table_path = table_path
        self._batch_size = batch_size
        self._run_id = str(run_id)
        self._task_key = str(task_key)
        self._buffer: List[dict] = []

        self._schema: StructType = self._load_table_schema()
        self._schema_field_names: list[str] = self._schema.fieldNames()
        self._schema_field_name_set: set[str] = set(self._schema_field_names)

    # ────────────────────────────────────────────────────────
    # Context manager protocol
    # ────────────────────────────────────────────────────────

    def __enter__(self) -> "BaseLogger":
        return self

    def __exit__(self, exc_type, exc_val, exc_tb) -> bool:
        """
        Flush remaining buffered records on block exit.

        If the caller's code raised and flush also fails, preserve the caller's
        original exception and only log the flush failure.
        """
        try:
            self.flush()
        except Exception as flush_exc:
            if exc_val is None:
                raise

            log.error(
                "Flush failed while exiting context manager for %s: %s",
                self._table_path,
                flush_exc,
            )

        return False

    # ────────────────────────────────────────────────────────
    # Public API
    # ────────────────────────────────────────────────────────

    def flush(self) -> None:
        """
        Append buffered records to the Delta table and clear the buffer.

        The buffer is only cleared after a successful write.
        """
        if not self._buffer:
            return

        try:
            aligned_records = [
                self._align_record_to_table_schema(record)
                for record in self._buffer
            ]

            df = self._spark.createDataFrame(
                aligned_records,
                schema=self._schema,
            )

            df.write.mode("append").format("delta").saveAsTable(self._table_path)

        except Exception as exc:
            log.warning(
                "Log flush failed for %s (%d record(s) retained): %s",
                self._table_path,
                len(self._buffer),
                exc,
            )
            raise RuntimeError(
                f"Failed to write {len(self._buffer)} log record(s) "
                f"to {self._table_path}"
            ) from exc

        self._buffer.clear()

    @property
    def buffer_size(self) -> int:
        """Number of records currently buffered."""
        return len(self._buffer)

    @property
    def table_path(self) -> str:
        """Fully-qualified target Delta table path."""
        return self._table_path

    @property
    def run_id(self) -> str:
        """Pipeline/job run identifier used by this logger."""
        return self._run_id

    @property
    def task_key(self) -> str:
        """Databricks task key used by this logger."""
        return self._task_key

    # ────────────────────────────────────────────────────────
    # Protected helpers for subclasses
    # ────────────────────────────────────────────────────────

    def _add_to_buffer(self, record: dict) -> None:
        """
        Append a fully-assembled record to the buffer and auto-flush
        when batch size is reached.
        """
        self._buffer.append(record)

        if len(self._buffer) >= self._batch_size:
            self.flush()

    def _execution_fields(self) -> dict:
        """
        Return execution-level metadata shared by all log rows.

        Processing-level fields such as source_table, target_table, and
        collection_instance_id are intentionally not included here because
        they may vary by logical step or by DataFrame row.
        """
        return {
            "run_id": self._run_id,
            "task_key": self._task_key,
        }

    def _validate_dataframe_size(self, df) -> int:
        """
        Confirm the DataFrame is small enough to safely collect to driver.

        Returns:
            Row count.

        Raises:
            ValueError: if the DataFrame exceeds the safety limit.
        """
        row_count = df.count()

        if row_count > self.DATAFRAME_ROW_LIMIT:
            raise ValueError(
                f"DataFrame has {row_count:,} rows, exceeding the safety "
                f"limit of {self.DATAFRAME_ROW_LIMIT:,}. Filter the input "
                f"to actual failures/events, or split into smaller batches "
                f"before calling log_dataframe()."
            )

        return row_count

    # ────────────────────────────────────────────────────────
    # Internal helpers
    # ────────────────────────────────────────────────────────

    def _load_table_schema(self) -> StructType:
        """
        Read schema from the target Delta table.

        Raises:
            TableContractError: if table does not exist.
        """
        if not self._spark.catalog.tableExists(self._table_path):
            raise TableContractError(
                f"Log table {self._table_path!r} does not exist. "
                f"It must be pre-created by migration SQL."
            )

        return self._spark.table(self._table_path).schema

    def _align_record_to_table_schema(self, record: dict) -> dict:
        """
        Strictly align a record dictionary to the target table schema.

        Behaviour:
            - Any extra field in the record that does not exist in the target
              table raises ValueError.
            - Any table column missing from the record is filled with None.
              Delta/table constraints will reject invalid NULLs if applicable.

        This protects against misspelled record keys being silently ignored.
        """
        extra_fields = set(record.keys()) - self._schema_field_name_set

        if extra_fields:
            raise ValueError(
                f"Record contains field(s) not present in target table "
                f"{self._table_path!r}: {sorted(extra_fields)}"
            )

        return {
            field_name: record.get(field_name)
            for field_name in self._schema_field_names
        }


class TableContractError(RuntimeError):
    """
    Raised when the target log Delta table is missing or unusable.
    """




event_logger.py

"""
EventLogger — structured writer for observation events into the events Delta table.

Writes non-fatal informational events during processing, for example:
- coding
- MI_fix
- edit
- imputation
- validation observation events

The logger receives run_id and task_key explicitly from notebook/job metadata.
Processing context such as source_table, target_table, and collection_instance_id
is supplied at log-call level because it can vary within a notebook.
"""

from __future__ import annotations

import uuid
from datetime import datetime, timezone
from typing import Optional

from pyspark.sql import SparkSession

from .base_logger import BaseLogger
from .table_resolver import ensure_logger_widgets, resolve_log_table_path


_LOG_TABLE_ENV_VAR = "CENSUS_EVENT_LOG_TABLE"
_DEFAULT_BATCH_SIZE = 10000


class EventLogger(BaseLogger):
    """
    Buffered writer for the social_census_logs.events Delta table.

    Not thread-safe. Use one instance per task/notebook execution.
    """

    def __init__(
        self,
        spark: SparkSession,
        table_path: str,
        run_id: str,
        task_key: str,
        batch_size: int = _DEFAULT_BATCH_SIZE,
    ):
        super().__init__(
            spark=spark,
            table_path=table_path,
            batch_size=batch_size,
            run_id=run_id,
            task_key=task_key,
        )

    # ────────────────────────────────────────────────────────
    # Factory
    # ────────────────────────────────────────────────────────

    @classmethod
    def for_task(
        cls,
        spark: SparkSession,
        *,
        run_id: str,
        task_key: str,
        log_table_path: Optional[str] = None,
        batch_size: int = _DEFAULT_BATCH_SIZE,
    ) -> "EventLogger":
        """
        Build a fully-configured EventLogger for a single task.

        Args:
            spark: Active SparkSession.
            run_id: Pipeline/job run ID passed from notebook/job metadata.
            task_key: Databricks task key passed from notebook/job metadata.
            log_table_path: Optional explicit events log table path.
            batch_size: Records to buffer before auto-flush.
        """
        ensure_logger_widgets()

        resolved_table = resolve_log_table_path(
            dataset="events",
            explicit_table_path=log_table_path,
            env_var_name=_LOG_TABLE_ENV_VAR,
            widget_name="event_log_table",
        )

        return cls(
            spark=spark,
            table_path=resolved_table,
            run_id=run_id,
            task_key=task_key,
            batch_size=batch_size,
        )

    # ────────────────────────────────────────────────────────
    # Public API — single record
    # ────────────────────────────────────────────────────────

    def log(
        self,
        *,
        event_type: str,
        message: str,
        source_table: Optional[str] = None,
        target_table: Optional[str] = None,
        collection_instance_id: Optional[str] = None,
        rule_name: Optional[str] = None,
        response_id: Optional[str] = None,
        case_id: Optional[str] = None,
        variable_name: Optional[str] = None,
    ) -> None:
        """
        Log one observation event.

        Args:
            event_type: Event category, e.g. coding, MI_fix, edit, imputation.
            message: Human-readable event message.
            source_table: Source table for this logical step.
            target_table: Target table for this logical step.
            collection_instance_id: Collection instance for this event, if known.
            rule_name: Optional business rule name.
            response_id: Optional response identifier.
            case_id: Optional case identifier.
            variable_name: Optional variable involved in the event.
        """
        record = self._build_record(
            event_type=event_type,
            message=message,
            source_table=source_table,
            target_table=target_table,
            collection_instance_id=collection_instance_id,
            rule_name=rule_name,
            response_id=response_id,
            case_id=case_id,
            variable_name=variable_name,
            timestamp=datetime.now(timezone.utc),
        )

        self._add_to_buffer(record)

    # ────────────────────────────────────────────────────────
    # Public API — DataFrame-based bulk logging
    # ────────────────────────────────────────────────────────

    def log_dataframe(
        self,
        df,
        *,
        event_type: str,
        source_table: Optional[str] = None,
        target_table: Optional[str] = None,
        rule_name: Optional[str] = None,
        rule_name_column: Optional[str] = None,
        message: Optional[str] = None,
        message_column: Optional[str] = None,
        response_id_column: str,
        case_id_column: Optional[str] = None,
        collection_instance_id: Optional[str] = None,
        collection_instance_id_column: Optional[str] = None,
        variable_name: Optional[str] = None,
        variable_name_column: Optional[str] = None,
    ) -> int:
        """
        Log every row of a DataFrame as a separate event record.

        Args:
            df: PySpark DataFrame, one row per event.
            event_type: Event category applied to every row.
            source_table: Source table for this logical step.
            target_table: Target table for this logical step.
            rule_name: Constant rule name.
            rule_name_column: Column containing per-row rule names.
            message: Constant message.
            message_column: Column containing per-row messages.
            response_id_column: Column containing response IDs.
            case_id_column: Optional column containing case IDs.
            collection_instance_id: Constant collection instance ID.
            collection_instance_id_column: Optional column containing per-row collection instance IDs.
            variable_name: Constant variable name.
            variable_name_column: Optional column containing per-row variable names.

        Returns:
            Number of event records added to the buffer.
        """
        if message is None and message_column is None:
            raise ValueError(
                "Either `message` or `message_column` must be supplied."
            )

        if message is not None and message_column is not None:
            raise ValueError(
                "Pass either `message` or `message_column`, not both."
            )

        if variable_name is not None and variable_name_column is not None:
            raise ValueError(
                "Pass either `variable_name` or `variable_name_column`, not both."
            )

        if rule_name is not None and rule_name_column is not None:
            raise ValueError(
                "Pass either `rule_name` or `rule_name_column`, not both."
            )

        if (
            collection_instance_id is not None
            and collection_instance_id_column is not None
        ):
            raise ValueError(
                "Pass either `collection_instance_id` or "
                "`collection_instance_id_column`, not both."
            )

        if response_id_column is None:
            raise ValueError("`response_id_column` is required.")

        for arg_name, col_name in [
            ("message_column", message_column),
            ("response_id_column", response_id_column),
            ("case_id_column", case_id_column),
            ("collection_instance_id_column", collection_instance_id_column),
            ("variable_name_column", variable_name_column),
            ("rule_name_column", rule_name_column),
        ]:
            if col_name is not None and col_name not in df.columns:
                raise ValueError(
                    f"Column {col_name!r} passed as {arg_name} not found. "
                    f"Available columns: {df.columns}"
                )

        row_count = self._validate_dataframe_size(df)

        if row_count == 0:
            return 0

        timestamp = datetime.now(timezone.utc)

        for row in df.collect():
            row_dict = row.asDict()

            record = self._build_record(
                event_type=event_type,
                message=(
                    row_dict[message_column]
                    if message_column
                    else message
                ),
                source_table=source_table,
                target_table=target_table,
