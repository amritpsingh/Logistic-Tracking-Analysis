from __future__ import annotations

import os
from typing import Optional, Union

from config_models.collection_config import Collection


DEFAULT_TARGET = "dev"
DEFAULT_COLLECTION = Collection.social_census.value


def get_dbutils():
    """
    Return Databricks dbutils when available, otherwise None.

    This keeps resolvers usable in:
      - Databricks notebooks
      - Databricks Jobs
      - local/unit-test contexts where dbutils is unavailable
    """
    try:
        from databricks.sdk.runtime import dbutils  # type: ignore[import-not-found]

        return dbutils
    except Exception:
        return None


def get_widget_value(name: str) -> Optional[str]:
    """
    Safely read a Databricks widget value.

    Returns None when:
      - not running in Databricks
      - dbutils is unavailable
      - widget does not exist
      - widget value is blank
    """
    dbutils = get_dbutils()
    if dbutils is None:
        return None

    try:
        value = dbutils.widgets.get(name)
    except Exception:
        return None

    if value is None or str(value).strip() == "":
        return None

    return str(value).strip()


def create_widget_if_missing(name: str, default_value: str) -> None:
    """
    Create a Databricks text widget if it does not already exist.

    If the widget already exists, this function leaves it unchanged.
    This is important for Databricks Jobs, where job parameters are already
    materialised as widgets before notebook code runs.
    """
    dbutils = get_dbutils()
    if dbutils is None:
        return

    try:
        # If this succeeds, widget already exists. Do not overwrite it.
        dbutils.widgets.get(name)
        return
    except Exception:
        pass

    try:
        dbutils.widgets.text(name, default_value)
    except Exception:
        # Do not make widget creation fatal. Resolver can still fall back to
        # environment variables or defaults.
        return


def ensure_props_widgets() -> None:
    """
    Ensure standard runtime property widgets exist.

    This mirrors parsing notebook defaults:
      - target defaults to dev
      - collection defaults to social_census
    """
    create_widget_if_missing("target", DEFAULT_TARGET)
    create_widget_if_missing("collection", DEFAULT_COLLECTION)


def _coerce_collection(collection: Union[str, Collection]) -> Collection:
    """
    Convert a collection value into a Collection enum.

    Supports:
      - Collection.social_census
      - "social_census"
      - "config_test_survey"
      - "census_strawman"
    """
    if isinstance(collection, Collection):
        return collection

    try:
        return Collection(collection)
    except ValueError:
        try:
            return Collection[collection]
        except KeyError:
            valid = ", ".join(c.value for c in Collection)
            raise ValueError(
                f"Invalid collection {collection!r}. Valid values are: {valid}"
            ) from None


def resolve_target() -> str:
    """
    Resolve target environment.

    Resolution order:
      1. Databricks widget: target
      2. Databricks widget: Target
      3. Environment variable: CENSUS_TARGET
      4. Default: dev
    """
    ensure_props_widgets()

    return (
        get_widget_value("target")
        or get_widget_value("Target")
        or os.environ.get("CENSUS_TARGET")
        or DEFAULT_TARGET
    )


def resolve_collection() -> Collection:
    """
    Resolve collection namespace.

    Resolution order:
      1. Databricks widget: collection
      2. Databricks widget: Collection
      3. Environment variable: CENSUS_COLLECTION
      4. Default: social_census
    """
    ensure_props_widgets()

    resolved = (
        get_widget_value("collection")
        or get_widget_value("Collection")
        or os.environ.get("CENSUS_COLLECTION")
        or DEFAULT_COLLECTION
    )

    return _coerce_collection(resolved)




