"""
ExceptionLogger — structured writer for Data Contract Technical Validation
failures and technical exceptions into the exceptions Delta table.

The logger receives run_id and task_key explicitly from notebook/job metadata.
Processing context such as source_table, target_table, and collection_instance_id
is supplied at log-call level because it can vary within a notebook and even
per DataFrame row.
"""

from __future__ import annotations

import json
import uuid
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Iterable, Optional, Union

from pyspark.sql import SparkSession

from .base_logger import BaseLogger
from .registry import (
    ErrorCodeRegistry,
    ResolvedCode,
    load_registry,
)
from .table_resolver import ensure_logger_widgets, resolve_log_table_path
from .violation import Violation


_LOG_TABLE_ENV_VAR = "CENSUS_EXCEPTION_LOG_TABLE"
_DEFAULT_BATCH_SIZE = 10000


def _to_loggable(value: Any) -> Optional"""
    Convert an expected value into a readable string for message generation.

    The expected value is not stored as a separate column.
    """
    if value is None:
        return None

    if isinstance(value, (bool, int, float, str)):
        return str(value)

    return json.dumps(value, default=str)


class ExceptionLogger(BaseLogger):
    """
    Buffered writer for the social_census_logs.exceptions Delta table.

    Not thread-safe. Use one instance per task/notebook execution.
    """

    def __init__(
        self,
        spark: SparkSession,
        registry: ErrorCodeRegistry,
        table_path: str,
        run_id: str,
        task_key: str,
        batch_size: int = _DEFAULT_BATCH_SIZE,
    ):
        super().__init__(
            spark=spark,
            table_path=table_path,
            batch_size=batch_size,
            run_id=run_id,
            task_key=task_key,
        )

        self._registry = registry

    # ────────────────────────────────────────────────────────
    # Factory
    # ────────────────────────────────────────────────────────

    @classmethod
    def for_task(
        cls,
        spark: SparkSession,
        *,
        run_id: str,
        task_key: str,
        log_table_path: Optional[str] = None,
        registry_path: Optional[Union[str, Path]] = None,
        batch_size: int = _DEFAULT_BATCH_SIZE,
    ) -> "ExceptionLogger":
        """
        Build a fully-configured ExceptionLogger for a single task.

        Args:
            spark: Active SparkSession.
            run_id: Pipeline/job run ID passed from notebook/job metadata.
            task_key: Databricks task key passed from notebook/job metadata.
            log_table_path: Optional explicit exceptions log table path.
            registry_path: Optional path to error code registry YAML.
            batch_size: Records to buffer before auto-flush.
        """
        registry = load_registry(registry_path)

        ensure_logger_widgets()

        resolved_table = resolve_log_table_path(
            dataset="exceptions",
            explicit_table_path=log_table_path,
            env_var_name=_LOG_TABLE_ENV_VAR,
            widget_name="exception_log_table",
        )

        return cls(
            spark=spark,
            registry=registry,
            table_path=resolved_table,
            run_id=run_id,
            task_key=task_key,
            batch_size=batch_size,
        )

    # ────────────────────────────────────────────────────────
    # Public API — single record
    # ────────────────────────────────────────────────────────

    def log(
        self,
        *,
        rule: str,
        event_type: str,
        source_table: Optional[str] = None,
        target_table: Optional[str] = None,
        collection_instance_id: Optional[str] = None,
        variable_name: Optional[str] = None,
        expected: Any = None,
        response_id: Optional[str] = None,
        case_id: Optional[str] = None,
        message: Optional[str] = None,
        stack_trace: Optional[str] = None,
    ) -> None:
        """
        Log one validation failure or technical exception.

        Args:
            rule: Validation rule key registered in error_codes.yml.
            event_type: Event category, e.g. DATACONTRACTVALIDATION.
            source_table: Source table for this logical step.
            target_table: Target table for this logical step.
            collection_instance_id: Collection instance for this exception, if known.
            variable_name: Variable involved in the failure, if applicable.
            expected: Expected value/pattern used for message generation only.
            response_id: Optional response identifier.
            case_id: Optional case identifier.
            message: Optional custom message.
            stack_trace: Optional traceback string.
        """
        resolved = self._registry.resolve(rule)

        record = self._build_record(
            resolved=resolved,
            event_type=event_type,
            rule=rule,
            source_table=source_table,
            target_table=target_table,
            collection_instance_id=collection_instance_id,
            variable_name=variable_name,
            expected=expected,
            response_id=response_id,
            case_id=case_id,
            message=message,
            stack_trace=stack_trace,
            timestamp=datetime.now(timezone.utc),
        )

        self._add_to_buffer(record)

    # ────────────────────────────────────────────────────────
    # Public API — multiple violations for one logical record
    # ────────────────────────────────────────────────────────

    def log_many(
        self,
        violations: Iterable[Violation],
        *,
        event_type: str,
        source_table: Optional[str] = None,
        target_table: Optional[str] = None,
        collection_instance_id: Optional[str] = None,
        response_id: Optional[str] = None,
        case_id: Optional[str] = None,
        stack_trace: Optional[str] = None,
    ) -> None:
        """
        Log many violations that share response_id, case_id, and event_type.
        """
        timestamp = datetime.now(timezone.utc)

        for violation in list(violations):
            resolved = self._registry.resolve(violation.rule)

            record = self._build_record(
                resolved=resolved,
                event_type=event_type,
                rule=violation.rule,
                source_table=source_table,
                target_table=target_table,
                collection_instance_id=collection_instance_id,
                variable_name=violation.variable_name,
                expected=violation.expected,
                response_id=response_id,
                case_id=case_id,
                message=violation.message,
                stack_trace=stack_trace,
                timestamp=timestamp,
            )

            self._add_to_buffer(record)

    # ────────────────────────────────────────────────────────
    # Public API — DataFrame-based bulk logging
    # ────────────────────────────────────────────────────────

    def log_dataframe(
        self,
        df,
        *,
        rule: Optional[str] = None,
        rule_column: Optional[str] = None,
        event_type: str,
        source_table: Optional[str] = None,
        target_table: Optional[str] = None,
        variable_name: Optional[str] = None,
        variable_name_column: Optional[str] = None,
        expected: Any = None,
        expected_column: Optional[str] = None,
        response_id_column: str,
        case_id_column: Optional[str] = None,
        collection_instance_id: Optional[str] = None,
        collection_instance_id_column: Optional[str] = None,
        message: Optional[str] = None,
        message_column: Optional[str] = None,
        stack_trace: Optional[str] = None,
    ) -> int:
        """
        Log every row of a DataFrame as a separate exception record.

        Args:
            df: PySpark DataFrame containing one row per failure.
            rule: Constant validation rule key.
            rule_column: Column containing per-row rule keys.
            event_type: Event category applied to every row.
            source_table: Source table for this logical step.
            target_table: Target table for this logical step.
            variable_name: Constant variable name.
            variable_name_column: Column containing per-row variable names.
            expected: Constant expected value used for message generation.
            expected_column: Column containing per-row expected values.
            response_id_column: Column containing response IDs.
            case_id_column: Optional column containing case IDs.
            collection_instance_id: Constant collection instance ID.
            collection_instance_id_column: Optional column containing per-row collection instance IDs.
            message: Constant custom message.
            message_column: Column containing per-row custom messages.
            stack_trace: Optional constant stack trace.

        Returns:
            Number of exception records added to the buffer.
        """
        if rule is None and rule_column is None:
            raise ValueError(
                "Either `rule` or `rule_column` must be supplied."
            )

        if rule is not None and rule_column is not None:
            raise ValueError(
                "Pass either `rule` or `rule_column`, not both."
            )

        if variable_name is not None and variable_name_column is not None:
            raise ValueError(
                "Pass either `variable_name` or `variable_name_column`, not both."
            )

        if expected is not None and expected_column is not None:
            raise ValueError(
                "Pass either `expected` or `expected_column`, not both."
            )

        if message is not None and message_column is not None:
            raise ValueError(
                "Pass either `message` or `message_column`, not both."
            )

        if (
            collection_instance_id is not None
            and collection_instance_id_column is not None
        ):
            raise ValueError(
                "Pass either `collection_instance_id` or "
                "`collection_instance_id_column`, not both."
            )

        if response_id_column is None:
            raise ValueError("`response_id_column` is required.")

        for arg_name, col_name in [
            ("rule_column", rule_column),
            ("message_column", message_column),
            ("response_id_column", response_id_column),
            ("case_id_column", case_id_column),
            ("variable_name_column", variable_name_column),
            ("expected_column", expected_column),
            ("collection_instance_id_column", collection_instance_id_column),
        ]:
            if col_name is not None and col_name not in df.columns:
                raise ValueError(
                    f"Column {col_name!r} passed as {arg_name} not found. "
                    f"Available columns: {df.columns}"
                )

        row_count = self._validate_dataframe_size(df)

        if row_count == 0:
            return 0

        timestamp = datetime.now(timezone.utc)
        resolved_cache: dict[str, ResolvedCode] = {}

        for row in df.collect():
            row_dict = row.asDict()

            rule_value = row_dict[rule_column] if rule_column else rule
            expected_value = (
                row_dict[expected_column]
                if expected_column
                else expected
            )

            if rule_value not in resolved_cache:
                resolved_cache[rule_value] = self._registry.resolve(rule_value)

            resolved = resolved_cache[rule_value]

            record = self._build_record(
                resolved=resolved,
                event_type=event_type,
                rule=rule_value,
                source_table=source_table,
                target_table=target_table,
                collection_instance_id=(
                    row_dict[collection_instance_id_column]
                    if collection_instance_id_column
                    else collection_instance_id
                ),
                variable_name=(
                    row_dict[variable_name_column]
                    if variable_name_column
                    else variable_name
                ),
                expected=expected_value,
                response_id=row_dict[response_id_column],
                case_id=(
                    row_dict[case_id_column]
                    if case_id_column
                    else None
                ),
                message=(
                    row_dict[message_column]
                    if message_column
                    else message
                ),
                stack_trace=stack_trace,
                timestamp=timestamp,
            )

            self._add_to_buffer(record)

        return row_count

    # ────────────────────────────────────────────────────────
    # Internal — record assembly
    # ────────────────────────────────────────────────────────

    def _build_record(
        self,
        *,
        resolved: ResolvedCode,
        event_type: str,
        rule: str,
        source_table: Optional[str],
        target_table: Optional[str],
        collection_instance_id: Optional[str],
        variable_name: Optional[str],
        expected: Any,
        response_id: Optional[str],
        case_id: Optional[str],
        message: Optional[str],
        stack_trace: Optional[str],
        timestamp: datetime,
    ) -> dict:
        expected_str = _to_loggable(expected)

        if message is None:
            if expected_str is not None:
                message = f"Rule '{rule}' failed. Expected={expected_str!r}"
            else:
                message = f"Rule '{rule}' failed."

        return {
            **self._execution_fields(),
            "id": str(uuid.uuid4()),
            "source_table": source_table,
            "target_table": target_table,
            "validation_level": resolved.validation_level.value,
            "event_type": event_type,
            "error_code": resolved.error_code,
            "severity": resolved.severity.value,
            "message": message,
            "response_id": response_id,
            "case_id": case_id,
            "collection_instance_id": collection_instance_id,
            "variable_name": variable_name,
            "is_blocking": resolved.is_blocking,
            "stack_trace": stack_trace,
            "created_timestamp_utc": timestamp,
        }



