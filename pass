"""
Generic JSON-blob parsing engine for ESS0 → ESS1.

`Parsing` reads survey response rows, parses the JSON content of selected
columns into queryable shapes, applies any declared array explodes, and
projects the configured output columns. Behaviour is driven entirely by
the transformation YAML: which input columns are JSON-typed, which output
columns to project, how nested JSON paths are addressed, and which output
rows come from exploded arrays.

`transform()` returns two DataFrames: the projected output and the
failure observations detected during parsing. Both outputs derive from
one parsed intermediate so the parsing logic is described once in the
plan; Spark still executes the plan once per materialisation.

ANSI-safety: invalid casts use `try_cast`, returning NULL rather than
throwing CAST_INVALID_INPUT. Outer explodes preserve the parent row when
the array is NULL so failure detection downstream still has the row to
work with.
"""

from functools import reduce
from typing import Optional

from pyspark.sql import DataFrame
from pyspark.sql.functions import (
    col,
    expr,
    explode_outer,
    from_json,
    length,
    lit,
    posexplode_outer,
    trim,
)
from pyspark.sql.types import ArrayType, MapType, StringType

from config_models.transformation_config import VariableConfig
from transformations.abstract_transformation import AbstractTransformation


# YAML type → Spark SQL type for use inside `try_cast`. String is handled
# separately because regular cast to string cannot fail.
_TRY_CAST_TYPES = {
    "integer":   "int",
    "tinyint":   "tinyint",
    "long":      "bigint",
    "timestamp": "timestamp",
}


class Parsing(AbstractTransformation):
    """
    Configurable JSON-blob parsing transformation.

    Reads JSON-typed input columns, parses nested JSON paths via
    rewritten expressions (e.g. `data:IF_name:1` becomes
    `get_json_object(data_json['IF_name'], '$.1')`), optionally explodes
    nested arrays, and projects the YAML-declared output columns.

    `transform()` returns (success_df, failures_df). Callers pass
    `failures_df` to `log_failures()` to write each observation into the
    exceptions table.
    """

    # Per-failure-type metadata used by `log_failures` to resolve the
    # registry rule, the `expected` value, and the human-readable message
    # for each row in the failures DataFrame.
    #
    # `cast` carries a message template — `expected` is resolved at log
    # time to the YAML-declared SQL type (one log call per type).
    FAILURE_META = {
        "json_parse": {
            "rule": "json_parse",
            "expected": "valid JSON (map<string,string>)",
            "message": "JSON parsing failed — raw value not parseable as map<string,string>.",
        },
        "explode_parse": {
            "rule": "explode_parse",
            "expected": "array<map<string,string>>",
            "message": "Array JSON not parseable as array<map<string,string>>.",
        },
        "cast": {
            "rule": "cast",
            "message": "try_cast(... as {sql_type}) returned NULL on non-blank input.",
        },
    }

    def __init__(self, spark, config_file: str):
        super().__init__(spark, config_file)

    # ──────────────────────────────────────────────────────────────────
    # Expression rewriting
    # ──────────────────────────────────────────────────────────────────

    def _rewrite_json_expression(self, expression: str, json_scopes: set) -> str:
        """
        Rewrite a YAML expression into a Spark SQL expression.

        Supported shapes:
            data:a            → data_json['a']
            data:a:b:c        → get_json_object(data_json['a'], '$.b.c')
            loop_x:y:z        → get_json_object(loop_x_json['y'], '$.z')

        Expressions whose first segment is not a known JSON scope are
        returned unchanged, so plain column references and arbitrary SQL
        flow through `expr()` untouched.
        """
        if ":" not in expression:
            return expression

        scope, *keys = expression.split(":")
        if scope not in json_scopes:
            return expression

        base = f"{scope}_json['{keys[0]}']"
        if len(keys) == 1:
            return base

        json_path = ".".join(keys[1:])
        return f"get_json_object({base}, '$.{json_path}')"

    def _base_sql_expr(self, variable: VariableConfig, json_scopes: set) -> Optional[str]:
        """
        Return the SQL string for a variable's source value before casting.

        Uses the rewritten JSON expression when `expression` is set;
        otherwise a backtick-escaped reference to the column named in
        `alias`. Returns None when neither is set.
        """
        if variable.expression:
            return self._rewrite_json_expression(variable.expression, json_scopes)
        if variable.alias:
            return f"`{variable.alias}`"
        return None

    # ──────────────────────────────────────────────────────────────────
    # Column construction
    # ──────────────────────────────────────────────────────────────────

    def _build_column(self, variable: VariableConfig, json_scopes: set):
        """
        Build a typed Spark column for a single output variable.

        Returns None when the variable is an explode driver — those rows
        are materialised upstream in `transform()`. Raises ValueError
        when the variable has neither expression nor alias, or declares
        an unsupported type.

        Casts to int, tinyint, bigint, and timestamp use `try_cast`, so
        invalid input becomes NULL rather than throwing under ANSI mode.
        String uses regular cast — casting to string does not fail.
        """
        if variable.expression and variable.expression.startswith(("explode:", "posexplode:")):
            return None

        spark_expr = self._base_sql_expr(variable, json_scopes)
        if spark_expr is None:
            raise ValueError(
                f"Variable '{variable.name}' must define either 'expression' or 'alias'."
            )

        if variable.type in _TRY_CAST_TYPES:
            sql_type = _TRY_CAST_TYPES[variable.type]
            col_expr = expr(f"try_cast({spark_expr} as {sql_type})")
        elif variable.type == "string":
            col_expr = expr(spark_expr).cast("string")
        else:
            raise ValueError(
                f"Unsupported type {variable.type!r} for variable {variable.name!r}."
            )

        return col_expr.alias(variable.name)

    # ──────────────────────────────────────────────────────────────────
    # YAML introspection helpers
    # ──────────────────────────────────────────────────────────────────

    def _get_json_input_columns(self) -> set:
        """Names of input variables declared as `type: json` in the YAML."""
        return {
            v.name
            for d in self._transform_config.input_datasets
            for v in (d.variables or [])
            if v.type == "json"
        }

    def _get_explode_specs(self) -> list:
        """
        Parse explode/posexplode expressions from output variables.

        Each spec is a dict with keys: name, explode_type, scope, path.
        Returned in YAML declaration order so dependent variables resolve
        correctly.
        """
        specs = []
        for v in self._transform_config.output_datasets[0].variables:
            if v.expression and v.expression.startswith(("explode:", "posexplode:")):
                explode_type, scope, path = v.expression.split(":", 2)
                specs.append({
                    "name": v.name,
                    "explode_type": explode_type,
                    "scope": scope,
                    "path": path,
                })
        return specs

    def _get_cast_sql_types(self) -> set:
        """SQL cast types ('int', 'timestamp') declared by non-internal output variables."""
        types = set()
        for v in self._transform_config.output_datasets[0].variables:
            if v.internal:
                continue
            if v.type == "integer":
                types.add("int")
            elif v.type == "timestamp":
                types.add("timestamp")
        return types

    @staticmethod
    def _nonblank(c):
        """Column predicate: not null AND, when cast to string, non-empty after trim."""
        return c.isNotNull() & (length(trim(c.cast("string"))) > 0)

    # ──────────────────────────────────────────────────────────────────
    # Public — parsing
    # ──────────────────────────────────────────────────────────────────

    def transform(self, data: dict, pk_column: str) -> tuple[DataFrame, DataFrame]:
        """
        Parse the input batch and return both the projected output and
        the failure observations.

        Pipeline:
            1. Parse JSON-typed input columns into map<string,string>.
            2. Apply each YAML-declared explode (outer variant).
            3. Record one failure row per detected issue:
                 * json_parse        — raw JSON did not parse
                 * explode_parse     — array JSON did not parse
                 * cast_<sql_type>   — try_cast returned NULL on non-blank input
            4. Exclude any input row whose primary key appears in the
               failure set, then project the configured output columns.

        Args:
            data: Dict of input DataFrames keyed by the YAML `key`
                (e.g. {"responses": <input DataFrame>}).
            pk_column: Name of the input column to use as the primary
                key for failure records (e.g. "responseId" for
                individual, "uoi" for household).

        Returns:
            (success_df, failures_df):
                success_df: DataFrame in target-table shape, only rows
                    that passed every check.
                failures_df: DataFrame[response_id, variable_name,
                    observed, failure_type], one row per failure
                    observation, deduplicated on (response_id,
                    variable_name, observed).

        Note:
            Returns a tuple, not a single DataFrame. Callers should
            drive read → transform → log_failures → write explicitly
            from the notebook; AbstractTransformation.run() assumes a
            single-DataFrame return and is not used with this subclass.
        """
        df = data["responses"]
        json_input_columns = self._get_json_input_columns()

        # 1. Parse JSON-typed input columns
        for c in json_input_columns:
            df = df.withColumn(
                f"{c}_json",
                from_json(col(c), MapType(StringType(), StringType())),
            )
        json_scopes = set(json_input_columns)

        failure_dfs: list[DataFrame] = []

        # 2. JSON parse failures — raw column non-blank but parsed result NULL
        for c in sorted(json_input_columns):
            failure_dfs.append(
                df.filter(self._nonblank(col(c)) & col(f"{c}_json").isNull())
                  .select(
                      col(pk_column).alias("response_id"),
                      lit(c).alias("variable_name"),
                      col(c).cast("string").alias("observed"),
                      lit("json_parse").alias("failure_type"),
                  )
            )

        # 3. Explode-parse failures (detected before explode) + apply outer explode
        for spec in self._get_explode_specs():
            raw_array = expr(f"{spec['scope']}_json['{spec['path']}']").cast("string")
            array_expr = from_json(raw_array, ArrayType(MapType(StringType(), StringType())))

            failure_dfs.append(
                df.filter(self._nonblank(raw_array) & array_expr.isNull())
                  .select(
                      col(pk_column).alias("response_id"),
                      lit(f"{spec['scope']}:{spec['path']}").alias("variable_name"),
                      raw_array.alias("observed"),
                      lit("explode_parse").alias("failure_type"),
                  )
            )

            if spec["explode_type"] == "posexplode":
                df = df.select(
                    "*",
                    posexplode_outer(array_expr).alias(f"{spec['name']}_index", spec["name"]),
                )
            else:
                df = df.withColumn(spec["name"], explode_outer(array_expr))
            df = df.withColumn(f"{spec['name']}_json", col(spec["name"]))
            json_scopes.add(spec["name"])

        # 4. Cast failures — try_cast returns NULL on non-blank input
        for v in self._transform_config.output_datasets[0].variables:
            if v.internal or v.type not in ("integer", "timestamp"):
                continue
            base_expr = self._base_sql_expr(v, json_scopes)
            if base_expr is None:
                continue

            sql_type = "int" if v.type == "integer" else "timestamp"
            failure_dfs.append(
                df.select(
                    col(pk_column).alias("response_id"),
                    expr(base_expr).cast("string").alias("observed"),
                    expr(f"try_cast({base_expr} as {sql_type})").alias("_casted"),
                )
                .filter(self._nonblank(col("observed")) & col("_casted").isNull())
                .select(
                    "response_id",
                    lit(v.name).alias("variable_name"),
                    "observed",
                    lit(f"cast_{sql_type}").alias("failure_type"),
                )
            )

        # 5. Combine and deduplicate failures. Dedup suppresses parent values
        # duplicated across exploded children that share the same observed value.
        if failure_dfs:
            failures_df = (
                reduce(lambda a, b: a.unionByName(b), failure_dfs)
                .dropDuplicates(["response_id", "variable_name", "observed"])
            )
        else:
            failures_df = self.spark.createDataFrame(
                [],
                "response_id string, variable_name string, observed string, failure_type string",
            )

        # 6. Build success rows: exclude inputs whose PK has any failure,
        # then project the configured non-internal output columns.
        failed_pks = failures_df.select("response_id").distinct()
        df_clean_inputs = df.join(
            failed_pks,
            df[pk_column] == failed_pks["response_id"],
            "left_anti",
        )

        output_columns = [
            col_expr
            for v in self._transform_config.output_datasets[0].variables
            if not v.internal
            if (col_expr := self._build_column(v, json_scopes)) is not None
        ]
        success_df = df_clean_inputs.select(*output_columns)

        return success_df, failures_df

    # ──────────────────────────────────────────────────────────────────
    # Public — logging
    # ──────────────────────────────────────────────────────────────────

    def log_failures(self, logger, failures_df: DataFrame, *, event_type: str = "PARSING") -> None:
        """
        Write every row of `failures_df` to the exceptions table via the
        given ExceptionLogger.

        Static failure types (json_parse, explode_parse) are logged in a
        single call each, reading metadata from `FAILURE_META`. Cast
        failures are logged with one call per SQL type declared in the
        YAML so each record carries the correct `expected` value and a
        type-specific message.
        """
        for failure_type in ("json_parse", "explode_parse"):
            meta = self.FAILURE_META[failure_type]
            subset = (
                failures_df
                .filter(col("failure_type") == failure_type)
                .select("response_id", "variable_name", "observed")
            )
            logger.log_dataframe(
                subset,
                rule=meta["rule"],
                event_type=event_type,
                variable_name_column="variable_name",
                expected=meta["expected"],
                response_id_column="response_id",
                observed_column="observed",
                message=meta["message"],
            )

        cast_meta = self.FAILURE_META["cast"]
        for sql_type in self._get_cast_sql_types():
            subset = (
                failures_df
                .filter(col("failure_type") == f"cast_{sql_type}")
                .select("response_id", "variable_name", "observed")
            )
            logger.log_dataframe(
                subset,
                rule=cast_meta["rule"],
                event_type=event_type,
                variable_name_column="variable_name",
                expected=sql_type,
                response_id_column="response_id",
                observed_column="observed",
                message=cast_meta["message"].format(sql_type=sql_type),
            )

    # ──────────────────────────────────────────────────────────────────
    # Public — output PK inference
    # ──────────────────────────────────────────────────────────────────

    def infer_output_pk(self, input_pk: str) -> str:
        """
        Return the output column whose expression equals `input_pk`.

        Used by the coverage check to map output rows back to their
        parent input row (e.g. input `uoi` → output `dwell_nbr` for
        dwelling_person). Raises ValueError when no non-internal output
        variable maps from the given input column.
        """
        for v in self._transform_config.output_datasets[0].variables:
            if not v.internal and v.expression == input_pk:
                return v.name
        raise ValueError(
            f"No non-internal output variable maps from input PK {input_pk!r}. "
            f"Add an output variable with `expression: {input_pk}` to the YAML."
        )
